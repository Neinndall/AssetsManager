<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
                    xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Themes/Colors.xaml"/>
        <ResourceDictionary Source="/Themes/ModernButton.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="HudWindowStyle" TargetType="{x:Type base:HudWindow}">
        <Setter Property="WindowStyle" Value="SingleBorderWindow"/>
        <Setter Property="WindowChrome.WindowChrome">
            <Setter.Value>
                <WindowChrome CaptionHeight="36" 
                              ResizeBorderThickness="8" 
                              GlassFrameThickness="0" 
                              CornerRadius="0" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type base:HudWindow}">
                    <Border x:Name="OuterBorder" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{StaticResource BorderColor}" 
                            BorderThickness="1"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}}" Value="Maximized">
                                        <Setter Property="CornerRadius" Value="0"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- 0: Title Bar -->
                                <RowDefinition Height="*"/>    <!-- 1: Client Area -->
                            </Grid.RowDefinitions>

                            <!-- 1. Custom Title Bar -->
                            <Border Grid.Row="0" Background="{StaticResource CardBackground}" Height="36" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Panel.ZIndex="100" Margin="-1.5,-1.5,-1.5,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="10,10,0,0"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}}" Value="Maximized">
                                                <Setter Property="CornerRadius" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/> <!-- Icon/Title -->
                                        <ColumnDefinition Width="*"/>    <!-- Drag Area -->
                                        <ColumnDefinition Width="Auto"/> <!-- Controls -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Title/Icon Area -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                        <!-- Image Logo (Standard WPF Icon) -->
                                        <Image Source="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}"
                                               Width="18" Height="18" 
                                               Margin="0,0,10,0"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="Source" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>

                                        <!-- Material Icon (Fallback if no Icon is set) -->
                                        <icons:MaterialIcon Kind="{Binding HeaderIcon, RelativeSource={RelativeSource TemplatedParent}}" 
                                                           Width="18" Height="18" 
                                                           Foreground="{StaticResource AccentBrush}" 
                                                           Margin="0,0,10,0">
                                            <icons:MaterialIcon.Style>
                                                <Style TargetType="icons:MaterialIcon">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </icons:MaterialIcon.Style>
                                        </icons:MaterialIcon>

                                        <TextBlock Text="{Binding HeaderTitle, RelativeSource={RelativeSource TemplatedParent}}" 
                                                   FontSize="13" 
                                                   Foreground="{StaticResource TextPrimary}" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Controls -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                                        <!-- Usamos comandos nativos de sistema vinculados a la ventana actual -->
                                        <Button Style="{StaticResource HUDTitleBarMinimizeButtonStyle}" 
                                                Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                                CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <icons:MaterialIcon Kind="WindowMinimize" Width="14" Height="14" Foreground="{StaticResource TextPrimary}"/>
                                        </Button>
                                        
                                        <Button CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource HUDTitleBarMaximizeButtonStyle}">
                                                    <!-- Comando por defecto: Maximizar -->
                                                    <Setter Property="Command" Value="{x:Static SystemCommands.MaximizeWindowCommand}"/>
                                                    <Style.Triggers>
                                                        <!-- Si ya está maximizada, cambiar a Restaurar -->
                                                        <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}}" Value="Maximized">
                                                            <Setter Property="Command" Value="{x:Static SystemCommands.RestoreWindowCommand}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>

                                        <Button x:Name="PART_Close" 
                                                Style="{StaticResource HUDTitleBarCloseButtonStyle}" 
                                                Command="{x:Static SystemCommands.CloseWindowCommand}"
                                                CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                                            <icons:MaterialIcon Kind="WindowClose" Width="14" Height="14" Foreground="{StaticResource TextPrimary}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 2. Main Content Area -->
                            <Border Grid.Row="1" ClipToBounds="True" Margin="-0.5,0,-0.5,-0.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="0,0,11.5,11.5"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource TemplatedParent}}" Value="Maximized">
                                                <Setter Property="CornerRadius" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
