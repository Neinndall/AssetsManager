<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">

    <!-- 1. PREMIUM STORE ITEM TEMPLATE -->
    <DataTemplate x:Key="StoreItemTemplate">
        <Border Background="{StaticResource CardBackground}" CornerRadius="12" Margin="8" Padding="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <!-- Image Area (Framed) -->
                    <Border Margin="12,12,12,0" Height="120">
                        <Grid>
                            <Border CornerRadius="10" Background="{StaticResource SidebarBackground}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="Black"/>
                                </Border.Effect>
                                <Border CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" ClipToBounds="True">
                                    <materialIcons:MaterialIcon Kind="TagOutline" Width="32" Height="32" Foreground="{StaticResource TextMuted}" Opacity="0.3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Border Padding="12">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}" TextAlignment="Center" MaxHeight="36" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                            
                            <!-- Price & Discount Container -->
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="{Binding FormattedOriginalPrice}" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,4" TextDecorations="Strikethrough"/>
                                
                                <!-- Discount Badge (Centered) -->
                                <TextBlock Text="{Binding Sale.FormattedSaleDetails, Mode=OneWay}" 
                                           Foreground="{StaticResource AccentGreen}" 
                                           FontWeight="Bold" FontSize="12" 
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,0"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="{Binding Sale.FormattedEndDate, Mode=OneWay}" FontSize="10" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,6,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- 2. MYTHIC ITEM TEMPLATE -->
    <DataTemplate x:Key="MythicItemTemplate">
        <Border Background="{StaticResource CardBackground}" CornerRadius="12" Margin="8" Padding="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <!-- Image Area (Framed) -->
                    <Border Margin="12,12,12,0" Height="120">
                        <Grid>
                            <Border CornerRadius="10" Background="{StaticResource SidebarBackground}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="Black"/>
                                </Border.Effect>
                                <Border CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" ClipToBounds="True">
                                    <materialIcons:MaterialIcon Kind="HexagonOutline" Width="32" Height="32" Foreground="{StaticResource AccentPurple}" Opacity="0.3" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Border Padding="12">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}" TextAlignment="Center" MaxHeight="36" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                <materialIcons:MaterialIcon Kind="DiamondStone" Width="14" Height="14" Foreground="{StaticResource AccentPurple}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Price}" Foreground="{StaticResource AccentPurple}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text=" ME" Foreground="{StaticResource AccentPurple}" FontWeight="Bold" FontSize="11" VerticalAlignment="Bottom" Margin="2,0,0,2"/>
                            </StackPanel>

                            <TextBlock Text="{Binding EndTime}" FontSize="10" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" Margin="0,6,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="PassRewardTemplate">
        <Border Background="{StaticResource CardBackground}" CornerRadius="12" Margin="8" Padding="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <!-- Header with Level - Centered -->
                    <Border Background="{StaticResource SidebarBackground}" CornerRadius="11,11,0,0" Padding="8,4" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                        <TextBlock Text="{Binding Level}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center"/>
                    </Border>

                    <!-- Image Area (Framed) -->
                    <Border Margin="12,12,12,0" Height="100">
                        <Grid>
                            <Border CornerRadius="10" Background="{StaticResource SidebarBackground}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2" Color="Black"/>
                                </Border.Effect>
                                <Border CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <!-- Placeholder Icon -->
                                        <materialIcons:MaterialIcon Kind="TicketPercentOutline" Width="32" Height="32" Foreground="{StaticResource AccentTeal}" Opacity="0.1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        
                                        <!-- Actual Reward Icon -->
                                        <Image Source="{Binding IconUrl}" Stretch="Uniform" Margin="4"/>

                                        <!-- Tier Badge INSIDE Image Area (Top-Right) -->
                                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="4">
                                            <!-- FREE Badge -->
                                            <Border Background="{StaticResource AccentGreen}" CornerRadius="6" Padding="5,2" Visibility="{Binding IsFree, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="FREE" FontSize="9" FontWeight="Black" Foreground="White"/>
                                            </Border>
                                            <!-- PREMIUM Badge (Optional, only if not free) -->
                                            <Border Background="{StaticResource AccentBlue}" CornerRadius="6" Padding="5,2" Visibility="{Binding IsFree, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <TextBlock Text="PASS" FontSize="9" FontWeight="Black" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Border Padding="12">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource TextPrimary}" TextAlignment="Center" MaxHeight="32" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding Details}" FontSize="10" Foreground="{StaticResource TextMuted}" TextAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" MaxHeight="28" TextTrimming="CharacterEllipsis"/>
                            
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="Qty: " FontSize="10" Foreground="{StaticResource TextMuted}"/>
                                <TextBlock Text="{Binding Quantity}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
