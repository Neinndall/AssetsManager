<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- HUD Slider Thumb Style: Suave y Elegante -->
    <Style x:Key="HUDSliderThumbStyle" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="true" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Width" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <!-- Subtle Glow Effect -->
                        <Ellipse x:Name="Glow" Fill="{StaticResource AccentBrush}" Opacity="0" Margin="-2"/>
                        
                        <!-- Main Circle (White) -->
                        <Ellipse x:Name="Background" Fill="White" Stroke="{StaticResource AccentBrush}" StrokeThickness="1" />
                        
                        <!-- Center Core (Small) -->
                        <Ellipse x:Name="InnerDot" Fill="{StaticResource AccentBrush}" Width="3" Height="3" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="true">
                            <Setter TargetName="Glow" Property="Opacity" Value="0.1" />
                            <Setter TargetName="InnerDot" Property="Width" Value="4" />
                            <Setter TargetName="InnerDot" Property="Height" Value="4" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="true">
                            <Setter TargetName="Glow" Property="Opacity" Value="0.2" />
                            <Setter TargetName="Background" Property="StrokeThickness" Value="1.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Main HUD Slider Style -->
    <Style x:Key="HUDSliderStyle" TargetType="Slider">
        <Setter Property="SnapsToDevicePixels" Value="true" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="MinHeight" Value="22"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Grid.Resources>
                            <Style TargetType="{x:Type RepeatButton}">
                                <Setter Property="OverridesDefaultStyle" Value="true" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Focusable" Value="false" />
                                <Setter Property="IsTabStop" Value="false" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Rectangle Fill="Transparent" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Grid.Resources>
                        
                        <!-- Background Track (Very subtle White) -->
                        <Border x:Name="TrackBackground" 
                                Background="#22FFFFFF" 
                                Height="2" 
                                CornerRadius="1" 
                                VerticalAlignment="Center" 
                                Margin="5,0"/>
                        
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="Thumb" Style="{StaticResource HUDSliderThumbStyle}" Panel.ZIndex="10"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="TrackBackground" Property="Opacity" Value="0.1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>