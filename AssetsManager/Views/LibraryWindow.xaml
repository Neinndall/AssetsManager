<UserControl x:Class="AssetsManager.Views.LibraryWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             FontFamily="{StaticResource AppFontFamily}">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Global Tools -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
        </Grid.RowDefinitions>

        <!-- 1. GLOBAL SEARCH & TOOLS -->
        <Border Grid.Row="0" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="GLOBAL ASSET LIBRARY" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding TotalAssetsCount, StringFormat='{}Tracking {0:N0} assets across the game'}" FontSize="10" Foreground="{StaticResource TextPrimary}" Opacity="0.8"/>
                </StackPanel>

                <!-- Unified Search Hub (Integrated) -->
                <Border Grid.Column="1" MaxWidth="500" Margin="40,0"
                        Background="{StaticResource SidebarBackground}" 
                        BorderBrush="{StaticResource BorderColor}" 
                        BorderThickness="1" 
                        CornerRadius="10" 
                        Padding="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="librarySearchBox" 
                                 Style="{StaticResource StandardSearchBoxStyle}" 
                                 Width="450" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged, Delay=300}"
                                 Tag="Search files in the whole library..."/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="REBUILD INDEX" 
                            Style="{StaticResource SecondaryButton}" 
                            Height="34" Padding="16,0"
                            Click="RebuildIndex_Click"
                            IsEnabled="{Binding IsIndexing, Converter={StaticResource InverseBooleanConverter}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. MAIN CONTENT AREA -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/> <!-- Categories Sidebar -->
                <ColumnDefinition Width="*"/>   <!-- Asset Gallery -->
            </Grid.ColumnDefinitions>

            <!-- Sidebar Categories -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,20">
                        <TextBlock Text="CATEGORIES" Style="{StaticResource ToolSectionLabel}" Margin="12,0,0,12"/>
                        <ListBox ItemsSource="{Binding Categories}" 
                                 SelectedItem="{Binding SelectedCategory}"
                                 Background="Transparent" 
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <RadioButton Content="{Binding}" 
                                                             IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                             Style="{StaticResource SettingsTabStyle}"
                                                             Tag="Label"
                                                             GroupName="LibraryCategories"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Asset Grid -->
            <Grid Grid.Column="1">
                <!-- Indexing Overlay -->
                <Border Panel.ZIndex="100" Background="#CC000000" Visibility="{Binding IsIndexing, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialIcons:MaterialIcon Kind="Sync" Width="48" Height="48" Foreground="{StaticResource AccentBrush}">
                            <materialIcons:MaterialIcon.Style>
                                <Style TargetType="materialIcons:MaterialIcon">
                                    <Style.Triggers>
                                        <Trigger Property="Visibility" Value="Visible">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource SpinningIconAnimation}"/>
                                            </Trigger.EnterActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </materialIcons:MaterialIcon.Style>
                        </materialIcons:MaterialIcon>
                        <TextBlock Text="{Binding ProgressText}" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,20,0,10" TextAlignment="Center"/>
                        <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Height="4" Width="300" Style="{StaticResource ModernProgressBar}"/>
                        <Button Content="CANCEL INDEXING" Style="{StaticResource SecondaryButton}" Margin="0,30,0,0" Width="150" Click="CancelIndexing_Click"/>
                    </StackPanel>
                </Border>

                <!-- Empty Library View -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Opacity="0.5"
                            Visibility="{Binding FilteredAssets.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Invert}">
                    <materialIcons:MaterialIcon Kind="Library" Width="64" Height="64" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="No assets found" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,0"/>
                    <TextBlock Text="Try adjusting your search or rebuild the index." FontSize="12"/>
                </StackPanel>

                <!-- Gallery -->
                <ListBox ItemsSource="{Binding FilteredAssets}" 
                         Style="{StaticResource ModernFileGridListBox}"
                         Margin="10">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="6" Width="140" Height="120" CornerRadius="10"
                                    Background="{StaticResource CardBackground}"
                                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Asset Type Indicator -->
                                    <Border Grid.Row="0" Background="{StaticResource SidebarBackground}" CornerRadius="9,9,0,0">
                                        <Grid>
                                            <materialIcons:MaterialIcon Kind="FileOutline" Width="32" Height="32" Foreground="{StaticResource TextMuted}" Opacity="0.3"/>
                                            <TextBlock Text="{Binding Extension}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8" FontSize="9" FontWeight="Black" Opacity="0.5"/>
                                        </Grid>
                                    </Border>

                                    <!-- Asset Info -->
                                    <Border Grid.Row="1" Padding="8,6" Background="{StaticResource SidebarBackground}" CornerRadius="0,0,9,9">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding WadSource}" FontSize="8" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
