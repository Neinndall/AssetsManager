<UserControl x:Class="AssetsManager.Views.Help.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <StackPanel Margin="0,16,0,0">
        <!-- SECTION: APPLICATION OVERVIEW -->
        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal">
                <materialIcons:MaterialIcon Kind="InformationOutline" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="APPLICATION OVERVIEW" FontSize="12" FontWeight="Black" Foreground="{StaticResource TextPrimary}" Margin="0,1,0,0"/>
                    <TextBlock Text="Technical identity and system metrics" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Opacity="0.8" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- HERO SECTION: Branding & Technical Identity -->
        <Border Background="{StaticResource CardBackground}" CornerRadius="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,40" Padding="32">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Visual Identity -->
                <Grid Grid.Column="0" VerticalAlignment="Top">
                    <Border Background="{StaticResource HoverColor}" CornerRadius="20" Width="120" Height="120" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <materialIcons:MaterialIcon Kind="DatabaseSearch" Width="56" Height="56" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <!-- Badge: Tool Type -->
                    <Border Background="{StaticResource AccentBrush}" CornerRadius="6" Padding="8,2" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-10">
                        <TextBlock Text="CORE SYSTEM" Foreground="White" FontSize="9" FontWeight="Black"/>
                    </Border>
                </Grid>

                <!-- Right: Information Matrix -->
                <StackPanel Grid.Column="1" Margin="32,0,0,0" VerticalAlignment="Center">
                    <!-- Main Title Area -->
                    <TextBlock Text="AssetsManager" FontSize="32" FontWeight="Black" Foreground="{StaticResource TextPrimary}"/>

                    <!-- Technical Sub-row (Identity Matrix Matrix) -->
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <!-- Version Badge -->
                        <Border Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="8,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="VERSION " Foreground="{StaticResource TextMuted}" FontSize="9" FontWeight="Black" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ApplicationVersion}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Build Integrity Status Badge (Pure MVVM Pattern) -->
                        <Border Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Padding="8,2" Margin="12,0,0,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <materialIcons:MaterialIcon Kind="{Binding BuildIcon}" Foreground="{Binding BuildBrush}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding BuildType}" FontSize="9" FontWeight="Black" Foreground="{Binding BuildBrush}" VerticalAlignment="Center" Opacity="0.8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,16" Opacity="0.5"/>

                    <!-- Description with technical layout -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Grid.Column="0" 
                                 Text="The definitive high-performance tool for League of Legends game data analysis and asset management. Engineered for precision and built for scale with multi-threaded extraction and real-time surveillance capabilities."
                                 Foreground="{StaticResource TextSecondary}"
                                 FontSize="13"
                                 LineHeight="22"
                                 TextWrapping="Wrap"
                                 FontWeight="Medium"
                                 MaxWidth="500"
                                 HorizontalAlignment="Left"/>

                        <!-- Technical Specs Summary -->
                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Top">
                            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,0,0" Padding="16,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="ENVIRONMENT" FontSize="9" FontWeight="Black" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text=".NET 10.0-WINDOWS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,12"/>
                                    
                                    <TextBlock Text="ARCH" FontSize="9" FontWeight="Black" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                    <TextBlock Text="X64 NATIVE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FEATURES GRID -->
        <TextBlock Text="CORE CAPABILITIES" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="4,0,0,16"/>
        <UniformGrid Columns="2">
            <!-- Feature 1 -->
            <Border Style="{StaticResource SettingsCard}" Margin="0,0,8,8" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource HoverColor}" Width="36" Height="36" CornerRadius="8">
                            <materialIcons:MaterialIcon Kind="CloudDownload" Foreground="{StaticResource AccentBlue}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Auto Downloads" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Seamlessly detects and downloads new PBE assets in the background." FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- Feature 2 -->
            <Border Style="{StaticResource SettingsCard}" Margin="8,0,0,8" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource HoverColor}" Width="36" Height="36" CornerRadius="8">
                            <materialIcons:MaterialIcon Kind="FileCompare" Foreground="{StaticResource AccentOrange}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="WAD Comparator" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Advanced differential analysis to pinpoint modified content." FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- Feature 3 -->
            <Border Style="{StaticResource SettingsCard}" Margin="0,8,8,8" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource HoverColor}" Width="36" Height="36" CornerRadius="8">
                            <materialIcons:MaterialIcon Kind="FolderSearch" Foreground="{StaticResource AccentGreen}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="File Explorer" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Browse internal archives with integrated instant previews." FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- Feature 4 -->
            <Border Style="{StaticResource SettingsCard}" Margin="8,8,0,8" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource HoverColor}" Width="36" Height="36" CornerRadius="8">
                            <materialIcons:MaterialIcon Kind="CubeOutline" Foreground="{StaticResource AccentPurple}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="3D Viewer" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="High-performance rendering of models, skeletons, and animations." FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- Feature 5 -->
            <Border Style="{StaticResource SettingsCard}" Margin="0,8,8,0" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource HoverColor}" Width="36" Height="36" CornerRadius="8">
                            <materialIcons:MaterialIcon Kind="Radar" Foreground="{StaticResource AccentRed}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Live Monitoring" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Real-time surveillance of remote configs and server health." FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>

            <!-- Feature 6 -->
            <Border Style="{StaticResource SettingsCard}" Margin="8,8,0,0" Padding="20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Background="{StaticResource HoverColor}" Width="36" Height="36" CornerRadius="8">
                            <materialIcons:MaterialIcon Kind="MusicNote" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Audio Banks" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="Decrypt, inspect, and playback encrypted audio bank events." FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- FOOTER -->
        <StackPanel HorizontalAlignment="Center" Margin="0,30,0,0">
            <TextBlock Text="© 2026 AssetsManager. All rights reserved." 
                       FontSize="11" 
                       Foreground="{StaticResource TextMuted}" 
                       TextAlignment="Center"/>
        </StackPanel>
    </StackPanel>
</UserControl>