<UserControl x:Class="AssetsManager.Views.HomeWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:converters="clr-namespace:AssetsManager.Views.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.Resources>
        
        <!-- Premium Dashboard Tile Style -->
        <Style x:Key="DashboardTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <TranslateTransform X="0" Y="0"/>
                            </Grid.RenderTransform>
                            
                            <!-- 1. Glow Layer -->
                            <Border x:Name="GlowBorder" CornerRadius="12" Opacity="0" IsHitTestVisible="False">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding Tag.Color, RelativeSource={RelativeSource TemplatedParent}}"/>
                                </Border.Background>
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>

                            <!-- 2. Background Layer -->
                            <Border x:Name="BackgroundBorder" 
                                    Background="{TemplateBinding Background}" 
                                    CornerRadius="12"/>

                            <!-- 3. Accent Strip Layer (Bottom Highlight) -->
                            <Border x:Name="AccentStrip" 
                                    BorderThickness="0,0,0,4"
                                    BorderBrush="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                    CornerRadius="12"
                                    Opacity="0.6"
                                    Margin="0"
                                    IsHitTestVisible="False"/>

                            <!-- 4. Content Layer (With Clipping) -->
                            <Border CornerRadius="12" ClipToBounds="True">
                                <ContentPresenter Margin="1"/>
                            </Border>

                            <!-- 5. Border Overlay -->
                            <Border x:Name="CardBorder"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"
                                    IsHitTestVisible="False"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="{StaticResource HoverColor}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter TargetName="CardBorder" Property="BorderThickness" Value="1.5"/>
                                <Setter TargetName="AccentStrip" Property="Opacity" Value="1"/>
                                <Setter TargetName="AccentStrip" Property="BorderThickness" Value="0,0,0,5"/>
                                <Setter TargetName="GlowBorder" Property="Opacity" Value="0.3"/> 
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" To="-4" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><PowerEase EasingMode="EaseOut" Power="3"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="RootGrid" Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <!-- Background Pattern (Subtle) -->
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0" RadiusX="1.0" RadiusY="1.0">
                <GradientStop Color="#08ffffff" Offset="0"/>
                <GradientStop Color="Transparent" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="50,40,50,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- 1. Hero -->
                    <RowDefinition Height="Auto"/> <!-- 2. Core Systems Section -->
                    <RowDefinition Height="Auto"/> <!-- 3. Utilities Section -->
                    <RowDefinition Height="Auto"/> <!-- 4. System Status (Footer) -->
                </Grid.RowDefinitions>

                <!-- 1. HERO SECTION -->
                <Grid Grid.Row="0" Margin="8,0,0,32">
                    <StackPanel>
                        <TextBlock Text="{Binding Greeting}" 
                                   FontSize="32" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimary}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="What would you like to do today?" 
                                   FontSize="14" 
                                   Foreground="{StaticResource TextSecondary}"
                                   Opacity="0.7"/>
                    </StackPanel>
                </Grid>

                <!-- 2. CORE SYSTEMS SECTION -->
                <StackPanel Grid.Row="1" Margin="0,0,0,24">
                    <TextBlock Text="CORE SYSTEMS" Style="{StaticResource ToolSectionLabel}" Margin="8,0,0,12"/>
                    <UniformGrid Columns="3">
                        <!-- LIVE -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Button_Click" Tag="{StaticResource AccentBlue}" Height="180">
                            <Button.CommandParameter>Explorer_Live</Button.CommandParameter>
                            <Grid Margin="24,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Top Info: Title + Status Badge -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Border Width="44" Height="44" CornerRadius="12" Background="#1A4FC1FF" Margin="0,0,16,0">
                                            <materialIcons:MaterialIcon Kind="ShieldCheckOutline" Width="24" Height="24" Foreground="{StaticResource AccentBlue}"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="LIVE" FontSize="11" FontWeight="Black" Foreground="{StaticResource AccentBlue}" Opacity="0.6"/>
                                            <TextBlock Text="Production" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </StackPanel>
                                    
                                    <!-- Status Badge -->
                                    <Border DockPanel.Dock="Right" VerticalAlignment="Top" Padding="8,3" CornerRadius="6" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A4CAF50"/>
                                                <Setter Property="BorderBrush" Value="#334CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLiveConfigured}" Value="False">
                                                        <Setter Property="Background" Value="#1AFF9100"/>
                                                        <Setter Property="BorderBrush" Value="#33FF9100"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="9" FontWeight="Black">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="READY"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLiveConfigured}" Value="False">
                                                            <Setter Property="Text" Value="SETUP"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DockPanel>

                                <TextBlock Grid.Row="1" Text="Explore the stable branch assets, current skins and game data." 
                                           FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" LineHeight="18"/>
                                <materialIcons:MaterialIcon Kind="Server" Width="80" Height="80" Foreground="{StaticResource AccentBlue}" Opacity="0.03" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-15,-15"/>
                            </Grid>
                        </Button>

                        <!-- PBE -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Button_Click" Tag="{StaticResource AccentOrange}" Height="180">
                            <Button.CommandParameter>Explorer_Pbe</Button.CommandParameter>
                            <Grid Margin="24,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Top Info: Title + Status Badge -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Border Width="44" Height="44" CornerRadius="12" Background="#1AFF9100" Margin="0,0,16,0">
                                            <materialIcons:MaterialIcon Kind="FlaskOutline" Width="24" Height="24" Foreground="{StaticResource AccentOrange}"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="BETA" FontSize="11" FontWeight="Black" Foreground="{StaticResource AccentOrange}" Opacity="0.6"/>
                                            <TextBlock Text="Public Beta" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border DockPanel.Dock="Right" VerticalAlignment="Top" Padding="8,3" CornerRadius="6" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A4CAF50"/>
                                                <Setter Property="BorderBrush" Value="#334CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPbeConfigured}" Value="False">
                                                        <Setter Property="Background" Value="#1AFF9100"/>
                                                        <Setter Property="BorderBrush" Value="#33FF9100"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="9" FontWeight="Black">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="READY"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPbeConfigured}" Value="False">
                                                            <Setter Property="Text" Value="SETUP"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DockPanel>

                                <TextBlock Grid.Row="1" Text="Access upcoming content and experiments before live release." 
                                           FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" LineHeight="18"/>
                                <materialIcons:MaterialIcon Kind="Flash" Width="80" Height="80" Foreground="{StaticResource AccentOrange}" Opacity="0.03" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-15,-15"/>
                            </Grid>
                        </Button>

                        <!-- LOCAL -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Button_Click" Tag="{StaticResource TextSecondary}" Height="180">
                            <Button.CommandParameter>Explorer_Local</Button.CommandParameter>
                            <Grid Margin="24,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Top Info: Title + Status Badge -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <Border Width="44" Height="44" CornerRadius="12" Background="#1AFFFFFF" Margin="0,0,16,0">
                                            <materialIcons:MaterialIcon Kind="FolderOpenOutline" Width="24" Height="24" Foreground="{StaticResource TextSecondary}"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="LOCAL" FontSize="11" FontWeight="Black" Foreground="{StaticResource TextSecondary}" Opacity="0.6"/>
                                            <TextBlock Text="Extracted" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border DockPanel.Dock="Right" VerticalAlignment="Top" Padding="8,3" CornerRadius="6" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#1A4CAF50"/>
                                                <Setter Property="BorderBrush" Value="#334CAF50"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLocalConfigured}" Value="False">
                                                        <Setter Property="Background" Value="#1AFF9100"/>
                                                        <Setter Property="BorderBrush" Value="#33FF9100"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="9" FontWeight="Black">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="READY"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLocalConfigured}" Value="False">
                                                            <Setter Property="Text" Value="MISSING"/>
                                                            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DockPanel>

                                <TextBlock Grid.Row="1" Text="Browse your extracted game files and locally saved archives." 
                                           FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" LineHeight="18"/>
                                <materialIcons:MaterialIcon Kind="FolderHomeOutline" Width="80" Height="80" Foreground="{StaticResource TextSecondary}" Opacity="0.03" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-15,-15"/>
                            </Grid>
                        </Button>

                        <!-- Comparator -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Button_Click" Tag="{StaticResource AccentBrush}" Height="180">
                            <Button.CommandParameter>Comparator</Button.CommandParameter>
                            <Grid Margin="24,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="44" Height="44" CornerRadius="12" Background="#1A5577CC" Margin="0,0,16,0">
                                        <materialIcons:MaterialIcon Kind="Compare" Width="24" Height="24" Foreground="{StaticResource AccentBrush}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="TOOLS" FontSize="11" FontWeight="Black" Foreground="{StaticResource AccentBrush}" Opacity="0.6"/>
                                        <TextBlock Text="Comparator" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Text="Perform deep differential analysis between WAD versions to track every change in game assets." 
                                           FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" LineHeight="18"/>
                            </Grid>
                        </Button>

                        <!-- Monitor -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Button_Click" Tag="{StaticResource AccentGreen}" Height="180">
                            <Button.CommandParameter>Monitor</Button.CommandParameter>
                            <Grid Margin="24,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="44" Height="44" CornerRadius="12" Background="#1A4CAF50" Margin="0,0,16,0">
                                        <materialIcons:MaterialIcon Kind="Radar" Width="24" Height="24" Foreground="{StaticResource AccentGreen}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="STATUS" FontSize="11" FontWeight="Black" Foreground="{StaticResource AccentGreen}" Opacity="0.6"/>
                                        <TextBlock Text="Monitor" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Text="Real-time server tracking, version discovery and automatic PBE update notifications." 
                                           FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" LineHeight="18"/>
                            </Grid>
                        </Button>

                        <!-- Viewer -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Button_Click" Tag="{StaticResource AccentPurple}" Height="180">
                            <Button.CommandParameter>Viewer</Button.CommandParameter>
                            <Grid Margin="24,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="44" Height="44" CornerRadius="12" Background="#1A9C27B0" Margin="0,0,16,0">
                                        <materialIcons:MaterialIcon Kind="CubeOutline" Width="24" Height="24" Foreground="{StaticResource AccentPurple}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="STUDIO" FontSize="11" FontWeight="Black" Foreground="{StaticResource AccentPurple}" Opacity="0.6"/>
                                        <TextBlock Text="Model Viewer" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock Grid.Row="1" Text="High-fidelity 3D viewport for skin inspection, animation playback and asset export." 
                                           FontSize="13" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" LineHeight="18"/>
                            </Grid>
                        </Button>
                    </UniformGrid>
                </StackPanel>

                <!-- 3. UTILITIES SECTION (Minimal Secondary Icons) -->
                <StackPanel Grid.Row="2" Margin="0,0,0,32">
                    <TextBlock Text="UTILITIES" Style="{StaticResource ToolSectionLabel}" Margin="8,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="4,0">
                         <!-- Notepad -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Notepad_Click" Tag="{StaticResource AccentOrange}" Height="48" Width="48" Margin="4" ToolTip="Quick Notepad">
                            <materialIcons:MaterialIcon Kind="NoteTextOutline" Width="20" Height="20" Foreground="{StaticResource AccentOrange}"/>
                        </Button>

                        <!-- Audio Player -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="AudioPlayer_Click" Tag="{StaticResource AccentBlue}" Height="48" Width="48" Margin="4" ToolTip="Audio Player">
                            <materialIcons:MaterialIcon Kind="Waveform" Width="20" Height="20" Foreground="{StaticResource AccentBlue}"/>
                        </Button>

                        <!-- Converter -->
                        <Button Style="{StaticResource DashboardTileStyle}" Click="Converter_Click" Tag="{StaticResource AccentTeal}" Height="48" Width="48" Margin="4" ToolTip="Asset Converter">
                            <materialIcons:MaterialIcon Kind="AutoFix" Width="20" Height="20" Foreground="{StaticResource AccentTeal}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- 4. SYSTEM STATUS FOOTER -->
                <Border Grid.Row="3" Background="{StaticResource SidebarBackground}" CornerRadius="12" Padding="20,12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <materialIcons:MaterialIcon Kind="{Binding IsConfigIncomplete, Converter={StaticResource BooleanToMaterialIconConverter}, ConverterParameter='AlertCircleOutline,CheckCircleOutline'}" 
                                                    Width="16" Height="16" Margin="0,0,10,0">
                            <materialIcons:MaterialIcon.Style>
                                <Style TargetType="materialIcons:MaterialIcon">
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConfigIncomplete}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.5" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialIcons:MaterialIcon.Style>
                        </materialIcons:MaterialIcon>
                        
                        <TextBlock Text="{Binding LastComparisonText}" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConfigIncomplete}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>