<Window x:Class="AssetsManager.Views.Dialogs.NotepadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
        Title="Notepad" Height="500" Width="400"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <!-- Borde Principal HUD con Sombra -->
    <Border Margin="10" Background="{StaticResource SidebarBackground}" 
            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.4"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: Custom Title Bar -->
                <RowDefinition Height="*"/>    <!-- 1: Main Content -->
            </Grid.RowDefinitions>

            <!-- 1. Custom Title Bar (HUD Style: 36px) -->
            <Border Grid.Row="0" Background="{StaticResource CardBackground}" Height="36" CornerRadius="11,11,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Panel.ZIndex="10" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Icon -->
                        <ColumnDefinition Width="Auto"/> <!-- Title -->
                        <ColumnDefinition Width="*"/>    <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/> <!-- Window Controls -->
                    </Grid.ColumnDefinitions>

                    <icons:MaterialIcon Grid.Column="0" Kind="NoteTextOutline" Width="18" Height="18" Foreground="{StaticResource AccentBrush}" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Notepad" FontSize="13" FontWeight="Normal" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="10,0,0,0"/>

                    <!-- HUD Window Controls (Minimize & Close only) -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource HUDTitleBarMinimizeButtonStyle}" Click="Minimize_Click">
                            <icons:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="PART_Close" Style="{StaticResource HUDTitleBarCloseButtonStyle}" Click="Close_Click">
                            <icons:MaterialIcon Kind="WindowClose" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Content Area -->
            <Grid Grid.Row="1" Margin="1">
                <avalonEdit:TextEditor x:Name="NotesEditor" 
                                     Style="{StaticResource BaseTextEditorStyle}"
                                     IsReadOnly="False"
                                     ShowLineNumbers="True"
                                     Padding="10"
                                     Margin="4"/>
            </Grid>
        </Grid>
    </Border>
</Window>