<base:HudWindow x:Class="AssetsManager.Views.Dialogs.UpdateProgressWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
                mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
                HeaderTitle="Downloading Update" 
                HeaderIcon="CloudDownload"
                Width="440" Height="180"
                WindowStartupLocation="CenterScreen"
                Style="{StaticResource HudWindowStyle}"
                ShowMaximizeButton="False"
                ResizeMode="CanMinimize">

    <Grid>
        <!-- 1. Dark Body Area (With bottom rounding) -->
        <Border Background="{StaticResource SidebarBackground}" CornerRadius="0,0,11,11" Padding="24" ClipToBounds="True">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="MessageTextBlock" 
                           Text="Initializing download..." 
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="14"
                           FontWeight="Medium"
                           Margin="0,0,0,20"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

                <ProgressBar x:Name="DownloadProgressBar" 
                             Height="10" 
                             Minimum="0" Maximum="100" 
                             HorizontalAlignment="Stretch" 
                             Style="{StaticResource ModernProgressBar}" 
                             BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</base:HudWindow>
