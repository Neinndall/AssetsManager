<Window x:Class="AssetsManager.Views.Dialogs.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
        Title="Downloading Update" Width="440" Height="200"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanMinimize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Border Margin="10" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="{StaticResource SidebarBackground}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: Custom Title Bar -->
                <RowDefinition Height="*"/>    <!-- 1: Body -->
            </Grid.RowDefinitions>

            <!-- 1. Custom Title Bar (HUD Style: 36px) -->
            <Border Grid.Row="0" Background="{StaticResource CardBackground}" Height="36" CornerRadius="11,11,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Panel.ZIndex="10" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Icon/Title -->
                        <ColumnDefinition Width="*"/>    <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/> <!-- Window Controls -->
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <materialIcons:MaterialIcon Kind="CloudDownload" 
                                                    Foreground="{StaticResource AccentBrush}" 
                                                    Width="18" Height="18" Margin="0,0,10,0"
                                                    VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                                   FontWeight="Normal" FontSize="13" 
                                   Foreground="{StaticResource TextPrimary}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Drag Area -->
                    <Rectangle Grid.Column="1" Fill="Transparent" IsHitTestVisible="True"/>

                    <!-- HUD Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource HUDTitleBarMinimizeButtonStyle}" Click="MinimizeButton_Click">
                            <materialIcons:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button Style="{StaticResource HUDTitleBarCloseButtonStyle}" Click="CloseButton_Click">
                            <materialIcons:MaterialIcon Kind="WindowClose" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Dark Body Area (With bottom rounding) -->
            <Border Grid.Row="1" Background="{StaticResource SidebarBackground}" CornerRadius="0,0,11,11" Padding="24" ClipToBounds="True">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="MessageTextBlock" 
                               Text="Initializing download..." 
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="14"
                               FontWeight="Medium"
                               Margin="0,0,0,20"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>

                    <ProgressBar x:Name="DownloadProgressBar" 
                                 Height="10" 
                                 Minimum="0" Maximum="100" 
                                 HorizontalAlignment="Stretch" 
                                 Style="{StaticResource ModernProgressBar}" 
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>