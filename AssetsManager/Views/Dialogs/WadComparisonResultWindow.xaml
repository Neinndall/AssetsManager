<base:HudWindow x:Class="AssetsManager.Views.Dialogs.WadComparisonResultWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:local="clr-namespace:AssetsManager.Views.Dialogs"
                xmlns:controls="clr-namespace:AssetsManager.Views.Dialogs.Controls"
                xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
                xmlns:viewModels="clr-namespace:AssetsManager.Views.Models.Dialogs"
                mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
                HeaderTitle="Comparison Results" 
                HeaderIcon="Compare"
                Height="850" Width="1450"
                MinWidth="1100" MinHeight="700"
                WindowStartupLocation="CenterScreen"
                Background="{StaticResource SidebarBackground}"
                Style="{StaticResource HudWindowStyle}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/> <!-- Sidebar -->
            <ColumnDefinition Width="*"/>    <!-- Content -->
        </Grid.ColumnDefinitions>

        <!-- 1. NAVIGATION SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0" Width="64">
            <StackPanel Margin="0,20">
                <!-- Advanced (Technical Tree) -->
                <RadioButton Style="{StaticResource ModernSidebarNavigationStyle}" 
                             IsChecked="{Binding ActiveView, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ComparisonViewMode.Advanced}, Mode=TwoWay}"
                             ToolTip="Hierarchy"
                             GroupName="ExplorerNavigation">
                    <Grid Width="64">
                        <icons:MaterialIcon Kind="FileTreeOutline" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </RadioButton>

                <!-- Discovery (Gallery) -->
                <RadioButton Style="{StaticResource ModernSidebarNavigationStyle}" 
                             IsChecked="{Binding ActiveView, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ComparisonViewMode.Discovery}, Mode=TwoWay}"
                             Margin="0,4,0,0" ToolTip="Gallery"
                             GroupName="ExplorerNavigation">
                    <Grid Width="64">
                        <icons:MaterialIcon Kind="ImageMultipleOutline" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </RadioButton>

                <!-- Overview -->
                <RadioButton Style="{StaticResource ModernSidebarNavigationStyle}" 
                             IsChecked="{Binding ActiveView, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ComparisonViewMode.Overview}, Mode=TwoWay}"
                             Margin="0,4,0,0" ToolTip="Overview"
                             GroupName="ExplorerNavigation">
                    <Grid Width="64">
                        <icons:MaterialIcon Kind="ViewDashboardOutline" Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- 2. MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- A. Global Smart Toolbar (Stats + Search) -->
                <RowDefinition Height="*"/>    <!-- B. View Container -->
                <RowDefinition Height="Auto"/> <!-- C. Footer -->
            </Grid.RowDefinitions>

            <!-- A. GLOBAL SMART TOOLBAR -->
            <Border Grid.Row="0" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="24,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="DIAGNOSTIC OVERVIEW" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,2"/>
                        <TextBlock Text="Asset Distribution &amp; Payload Analysis" FontSize="10" Foreground="{StaticResource TextPrimary}" Opacity="0.8"/>
                    </StackPanel>

                    <!-- Unified Diagnostic Control Hub (Search + Filters) -->
                    <Border Grid.Column="1" Grid.ColumnSpan="2" 
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="{StaticResource SidebarBackground}"
                            BorderBrush="{StaticResource BorderColor}" 
                            BorderThickness="1"
                            CornerRadius="10" 
                            Padding="0">
                        <StackPanel Orientation="Horizontal">
                            <!-- Global Search Zone -->
                            <TextBox x:Name="globalSearchBox" 
                                     Style="{StaticResource StandardSearchBoxStyle}" 
                                     Width="280" 
                                     Background="Transparent"
                                     BorderThickness="0"
                                     TextChanged="GlobalSearchBox_TextChanged"
                                     Tag="Search files..."/>

                            <!-- Technical Separator -->
                            <Rectangle Width="1" Fill="{StaticResource BorderColor}" Margin="12,6" VerticalAlignment="Stretch"/>

                            <!-- Global Interactive Filters -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                                <ToggleButton Style="{StaticResource DiagnosticBadgeToggleStyle}" 
                                              IsChecked="{Binding TreeModel.ShowNew}"
                                              ToolTip="Toggle: New Assets">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <icons:MaterialIcon Kind="PlusCircleOutline" Foreground="{StaticResource AccentGreen}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="NEW" FontSize="10" FontWeight="Black" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,1,8,0" Opacity="0.8"/>
                                        <TextBlock Text="{Binding CountNew}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                    </StackPanel>
                                </ToggleButton>

                                <ToggleButton Style="{StaticResource DiagnosticBadgeToggleStyle}" 
                                              IsChecked="{Binding TreeModel.ShowModified}"
                                              ToolTip="Toggle: Modified Assets">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <icons:MaterialIcon Kind="PencilCircleOutline" Foreground="{StaticResource AccentBlue}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="MODIFIED" FontSize="10" FontWeight="Black" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,1,8,0" Opacity="0.8"/>
                                        <TextBlock Text="{Binding CountModified}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                    </StackPanel>
                                </ToggleButton>

                                <ToggleButton Style="{StaticResource DiagnosticBadgeToggleStyle}" 
                                              IsChecked="{Binding TreeModel.ShowRemoved}"
                                              ToolTip="Toggle: Removed Assets">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <icons:MaterialIcon Kind="MinusCircleOutline" Foreground="{StaticResource AccentRed}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="REMOVED" FontSize="10" FontWeight="Black" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,1,8,0" Opacity="0.8"/>
                                        <TextBlock Text="{Binding CountRemoved}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                    </StackPanel>
                                </ToggleButton>

                                <ToggleButton Style="{StaticResource DiagnosticBadgeToggleStyle}" 
                                              IsChecked="{Binding TreeModel.ShowRenamed}"
                                              ToolTip="Toggle: Renamed Assets"
                                              Margin="0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <icons:MaterialIcon Kind="SwapHorizontalCircleOutline" Foreground="{StaticResource AccentOrange}" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="RENAMED" FontSize="10" FontWeight="Black" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" Margin="0,1,8,0" Opacity="0.8"/>
                                        <TextBlock Text="{Binding CountRenamed}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                    </StackPanel>
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- B. VIEW CONTAINER (Dynamic Content) -->
            <Grid Grid.Row="1">
                <!-- Overview View -->
                <controls:WadComparisonOverviewControl Visibility="{Binding ActiveView, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ComparisonViewMode.Overview}}"/>
                
                <!-- Discovery View -->
                <controls:WadComparisonGalleryControl Visibility="{Binding ActiveView, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ComparisonViewMode.Discovery}}"/>
                
                <!-- Advanced View (Hierarchy + Details) -->
                <Grid Visibility="{Binding ActiveView, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static viewModels:ComparisonViewMode.Advanced}}">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="45*" MinWidth="300"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="55*" MinWidth="300"/>
                        </Grid.ColumnDefinitions>

                        <controls:WadResultsTreeControl x:Name="ResultsTree" Grid.Column="0" DataContext="{Binding TreeModel}"/>
                        <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="Transparent" ShowsPreview="False"/>
                        <controls:WadDiffDetailsControl x:Name="DiffDetails" Grid.Column="2" DataContext="{Binding DetailsModel.SelectedDiff}"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- C. FOOTER ACTIONS -->
            <Border Grid.Row="2" Background="{StaticResource CardBackground}" CornerRadius="0,0,11,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="24,12">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <icons:MaterialIcon Kind="InformationOutline" Width="16" Height="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SummaryText}" FontSize="11" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Reload Hashes" Click="ReloadHashesButton_Click" Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,10,0" Padding="15,0"/>
                        <Button Content="Save Results" Click="SaveButton_Click" Style="{StaticResource SecondaryButton}" Height="32" Padding="20,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</base:HudWindow>
