<base:HudWindow x:Class="AssetsManager.Views.Dialogs.UpdatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
        mc:Ignorable="d"
        Title="Software Updates" Height="650" Width="850"
        MinHeight="650" MinWidth="850"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SidebarBackground}"
        HeaderTitle="Software Updates" 
        HeaderIcon="Update"
        Style="{StaticResource HudWindowStyle}"
        FontFamily="{StaticResource AppFontFamily}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR: CURRENT STATUS -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}" Padding="32,24,32,16" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource CardBackground}" CornerRadius="12" Width="48" Height="48" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <materialIcons:MaterialIcon Kind="RocketLaunchOutline" Width="24" Height="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="DEVELOPMENT BRANCH" FontWeight="Black" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="Current Version: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentVersion}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnRefresh" Content="REFRESH HISTORY" Style="{StaticResource SecondaryButton}" Height="34" Padding="16,0" Click="BtnRefresh_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT: COMMIT HISTORY -->
        <Grid Grid.Row="1">
            <!-- Loading Indicator -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <materialIcons:MaterialIcon Kind="Sync" Width="48" Height="48" Foreground="{StaticResource AccentBrush}" RenderTransformOrigin="0.5,0.5">
                    <materialIcons:MaterialIcon.RenderTransform>
                        <RotateTransform Angle="0" x:Name="SpinnerRotate"/>
                    </materialIcons:MaterialIcon.RenderTransform>
                    <materialIcons:MaterialIcon.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </materialIcons:MaterialIcon.Triggers>
                </materialIcons:MaterialIcon>
                <TextBlock Text="Updating development history..." FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Commits List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,16" Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding Commits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,12" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Author Avatar (Placeholder for HUD style) -->
                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="{StaticResource CardBackground}" Margin="0,0,16,0" VerticalAlignment="Top">
                                        <materialIcons:MaterialIcon Kind="AccountOutline" Width="18" Height="18" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Commit Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Commit.Author.Name}" FontWeight="Black" FontSize="12" Foreground="{StaticResource TextPrimary}"/>
                                            <Border Background="{StaticResource SidebarBackground}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                                <TextBlock Text="{Binding ShortSha}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" FontFamily="Consolas"/>
                                            </Border>
                                            <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="6,2" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsLatest, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="LATEST" FontSize="9" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Margin="0,-0.5,0,0"/>
                                            </Border>
                                        </StackPanel>
                                        
                                        <TextBlock Text="{Binding Commit.Message}" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                        
                                        <TextBlock Text="{Binding Commit.Author.Date, StringFormat='{}Committed {0:MMM dd, yyyy HH:mm}'}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Opacity="0.7" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Download Action -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <Button x:Name="BtnDownload"
                                                Content="DOWNLOAD &amp; INSTALL"
                                                Style="{StaticResource PrimaryButton}"
                                                Height="30" Padding="14,0"
                                                FontSize="10" FontWeight="Black"
                                                Click="BtnDownload_Click"
                                                Visibility="{Binding DownloadableAsset, Converter={StaticResource NullToVisibilityConverter}}"/>

                                        <TextBlock Text="No build available"
                                                 FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}"
                                                 HorizontalAlignment="Right"
                                                 Visibility="{Binding DownloadableAsset, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                    </StackPanel>                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- FOOTER: INFO -->
        <Border Grid.Row="2" Background="{StaticResource CardBackground}" Padding="32,12" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="Github" Width="16" Height="16" Foreground="{StaticResource AccentBrush}" Opacity="0.6"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" FontSize="11" FontWeight="SemiBold" Margin="10,0,0,0"/>
                </StackPanel>

                <Button Content="CLOSE WINDOW" HorizontalAlignment="Right" Style="{StaticResource SecondaryButton}" Height="32" Padding="20,0" Click="BtnClose_Click"/>
            </Grid>
        </Border>
    </Grid>
</base:HudWindow>
