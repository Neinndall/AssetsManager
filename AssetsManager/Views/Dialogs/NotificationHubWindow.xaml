<base:HudWindow x:Class="AssetsManager.Views.Dialogs.NotificationHubWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                xmlns:models="clr-namespace:AssetsManager.Views.Models.Notifications"
                xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
                mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
                HeaderTitle="Notifications" 
                HeaderIcon="BellOutline"
                Height="500" Width="400"
                WindowStartupLocation="CenterOwner"
                Style="{StaticResource HudWindowStyle}"
                ShowMaximizeButton="False"
                ResizeMode="NoResize">

    <Window.Resources>
        <!-- DataTemplate for Notifications -->
        <DataTemplate DataType="{x:Type models:NotificationModel}">
            <Grid Margin="0,0,0,10" Cursor="Hand">
                <!-- 1. Background Layer -->
                <Border x:Name="NotificationBackground" 
                        Background="{StaticResource CardBackground}" 
                        CornerRadius="8"/>

                <!-- 2. Content Layer (Fixed Padding, never shifts) -->
                <Border Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- 0: Icon -->
                            <ColumnDefinition Width="*"/>    <!-- 1: Body -->
                            <ColumnDefinition Width="Auto"/> <!-- 2: Close -->
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Row 0: Header (Icon + Title + Time) -->
                            <RowDefinition Height="*"/>    <!-- Row 1: Message -->
                        </Grid.RowDefinitions>

                        <!-- 1. Technical Icon (Aligned with Title line) -->
                        <materialIcons:MaterialIcon Grid.Row="0" Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center" Margin="0,1,12,0">
                            <materialIcons:MaterialIcon.Style>
                                <Style TargetType="materialIcons:MaterialIcon">
                                    <Setter Property="Kind" Value="InformationOutline"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="Success">
                                            <Setter Property="Kind" Value="CheckCircleOutline"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="Warning">
                                            <Setter Property="Kind" Value="AlertOutline"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="Error">
                                            <Setter Property="Kind" Value="CloseCircleOutline"/>
                                            <Setter Property="Foreground" Value="{StaticResource AccentRed}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialIcons:MaterialIcon.Style>
                        </materialIcons:MaterialIcon>

                        <!-- 2. Header: Title - Time (Perfectly aligned with Icon) -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                            <TextBlock Text="{Binding Title, Converter={StaticResource StringCaseConverter}}" 
                                       FontWeight="Black" 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextMuted}" 
                                       VerticalAlignment="Center"/>
                            
                            <TextBlock Text="-" 
                                       FontSize="11" 
                                       Foreground="{StaticResource TextMuted}" 
                                       Margin="6,0" 
                                       Opacity="0.5"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding Timestamp, StringFormat='HH:mm'}" 
                                       FontSize="11" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMuted}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- 3. Main Message (Below Header) -->
                        <TextBlock Grid.Row="1" Grid.Column="1" 
                                   Text="{Binding Message}" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextPrimary}" 
                                   TextWrapping="Wrap"
                                   LineHeight="15"
                                   LineStackingStrategy="BlockLineHeight"
                                   Opacity="0.85"/>

                        <!-- 4. Close Action (Centered vertically in the whole card) -->
                        <Grid Grid.Column="2" Grid.RowSpan="2" VerticalAlignment="Center" Margin="16,0,0,0">
                            <Button Style="{StaticResource TransparentIconButton}" 
                                    Width="24" Height="24" 
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Click="RemoveNotification_Click"
                                    ToolTip="Dismiss">
                                <materialIcons:MaterialIcon Kind="Close" Width="14" Height="14" Opacity="0.4"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <!-- 3. Border Overlay (Changes thickness without shifting layout) -->
                <Border x:Name="NotificationBorder" 
                        BorderBrush="{StaticResource BorderColor}" 
                        BorderThickness="1"
                        CornerRadius="8"
                        IsHitTestVisible="False"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsRead}" Value="False">
                    <Setter TargetName="NotificationBorder" Property="BorderThickness" Value="1.5"/>
                    <Setter TargetName="NotificationBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </DataTrigger>
                <!-- Type-specific accents for Unread status -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRead}" Value="False"/>
                        <Condition Binding="{Binding Type}" Value="Success"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="NotificationBorder" Property="BorderBrush" Value="{StaticResource AccentGreen}"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRead}" Value="False"/>
                        <Condition Binding="{Binding Type}" Value="Warning"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="NotificationBorder" Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsRead}" Value="False"/>
                        <Condition Binding="{Binding Type}" Value="Error"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="NotificationBorder" Property="BorderBrush" Value="{StaticResource AccentRed}"/>
                </MultiDataTrigger>
                
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="NotificationBackground" Property="Background" Value="{StaticResource HoverColor}"/>
                </Trigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0: Actions Area (Header) -->
            <RowDefinition Height="*"/>    <!-- 1: Content Area -->
        </Grid.RowDefinitions>

        <!-- 1. Actions Area (Header under Title Bar) -->
        <Border Grid.Row="0" Padding="20,10" Background="{StaticResource CardBackground}" 
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                Visibility="{Binding Notifications.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Recent activity" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                    <Border Background="#26FF5252" BorderBrush="{StaticResource AccentRed}" BorderThickness="1" CornerRadius="6" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center" 
                            Visibility="{Binding HasUnread, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialIcons:MaterialIcon Kind="BellAlertOutline" Width="12" Height="12" Foreground="{StaticResource AccentRed}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding UnreadCount}" Foreground="{StaticResource AccentRed}" FontSize="10" FontWeight="Black" VerticalAlignment="Center"/>
                            <TextBlock Text="NEW" Foreground="{StaticResource AccentRed}" FontSize="9" FontWeight="Bold" Margin="4,0,0,0" Opacity="0.9" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="{Binding Notifications.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <Button Style="{StaticResource TransparentIconButton}" Click="MarkAllRead_Click" Margin="0,0,8,0" Padding="6,4">
                        <StackPanel Orientation="Horizontal">
                            <materialIcons:MaterialIcon Kind="CheckAll" Width="14" Height="14" Foreground="{StaticResource AccentGreen}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Mark Read" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TransparentIconButton}" Click="ClearAll_Click" Padding="6,4">
                        <StackPanel Orientation="Horizontal">
                            <materialIcons:MaterialIcon Kind="DeleteOutline" Width="14" Height="14" Foreground="{StaticResource AccentRed}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Clear All" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Content Area (With bottom rounding) -->
        <Border Grid.Row="1" Background="{StaticResource SidebarBackground}" CornerRadius="0,0,11,11" ClipToBounds="True">
            <Grid>
                <!-- Empty State -->
                <Grid Visibility="{Binding Notifications.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Invert}" Margin="0,40,0,40">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Background="{StaticResource CardBackground}" CornerRadius="50" Width="80" Height="80" Margin="0,0,0,16">
                            <materialIcons:MaterialIcon Kind="BellSleepOutline" Width="32" Height="32" Foreground="{StaticResource TextMuted}" Opacity="0.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="All caught up!" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="No new notifications at the moment." FontSize="13" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- List Area -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16" 
                              Visibility="{Binding Notifications.Count, Converter={StaticResource CountToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{Binding Notifications}"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</base:HudWindow>
