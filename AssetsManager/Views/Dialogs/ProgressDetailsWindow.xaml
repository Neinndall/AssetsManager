<base:HudWindow x:Class="AssetsManager.Views.Dialogs.ProgressDetailsWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
                mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
                Height="Auto" Width="600" 
                SizeToContent="Height"
                WindowStartupLocation="CenterOwner"
                Style="{StaticResource HudWindowStyle}"
                ShowMaximizeButton="False"
                ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Dark Body Area -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}">
            <Grid Margin="24">
                <StackPanel>
                    <!-- Technical Status Card -->
                    <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="20" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <StackPanel>
                            <!-- 1. Operation and Progress -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock x:Name="VerbTextBlock" 
                                           Text="{Binding OperationVerb}" 
                                           FontWeight="SemiBold" FontSize="15" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text=":" 
                                           FontWeight="SemiBold" FontSize="15" 
                                           Foreground="{StaticResource TextPrimary}"
                                           Margin="0,0,10,0"/>
                                <TextBlock x:Name="ItemProgressTextBlock" 
                                           Text="{Binding ItemProgressText}" 
                                           FontSize="15" 
                                           Foreground="{StaticResource TextPrimary}" 
                                           FontWeight="SemiBold"
                                           FontFamily="Consolas"/>
                            </StackPanel>

                            <!-- 2. Current File Name -->
                            <Grid Margin="0,0,0,12">
                                <TextBlock x:Name="CurrentFileTextBlock" 
                                           Text="{Binding CurrentFileName}" 
                                           FontSize="12" 
                                           Foreground="{StaticResource TextSecondary}" 
                                           TextTrimming="CharacterEllipsis"
                                           FontWeight="Medium"/>
                            </Grid>

                            <!-- 3. Visual Progress Bar -->
                            <Grid Margin="0,0,0,12">
                                <ProgressBar x:Name="MainProgressBar" 
                                             Height="8" 
                                             Minimum="0" Maximum="100" 
                                             Value="{Binding ProgressValue}"
                                             Style="{StaticResource ModernProgressBar}"/>
                            </Grid>
                            
                            <!-- 4. Technical Data Area -->
                            <StackPanel>
                                <!-- Sub-progress Row -->
                                <StackPanel x:Name="SubProgressRow" Orientation="Horizontal" Margin="0,0,0,10" Visibility="{Binding SubProgressVisibility}">
                                    <materialIcons:MaterialIcon Kind="ChartBubble" Width="14" Height="14" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SubProgressTextBlock" 
                                               Text="{Binding SubProgressText}" 
                                               FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"/>
                                </StackPanel>

                                <!-- Estimated Time Row -->
                                <StackPanel Orientation="Horizontal">
                                    <materialIcons:MaterialIcon Kind="ClockTimeFourOutline" Width="14" Height="14" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="EstimatedTimeTextBlock" 
                                               Text="{Binding EstimatedTimeText}" 
                                               FontSize="12" 
                                               Foreground="{StaticResource TextSecondary}" 
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Footer Area (Actions) -->
        <Border Grid.Row="1" Background="{StaticResource CardBackground}" 
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" 
                Padding="20,14" CornerRadius="0,0,11,11">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource SecondaryButton}" Click="CancelButton_Click" Height="32" Width="90"/>
            </StackPanel>
        </Border>
    </Grid>
</base:HudWindow>
