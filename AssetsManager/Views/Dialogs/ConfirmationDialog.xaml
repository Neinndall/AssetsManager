<Window x:Class="AssetsManager.Views.Dialogs.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:AssetsManager.Views.Dialogs"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
        Title="Confirmation" Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner" 
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" 
                      ResizeBorderThickness="0" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <!-- Margen para la sombra HUD -->
    <Border Margin="10" Background="{StaticResource SidebarBackground}" 
            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.4"/>
        </Border.Effect>
        
        <StackPanel>
            <!-- 1. Header Area (HUD Style 36px) -->
            <Border Height="36" Background="{StaticResource CardBackground}" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                    CornerRadius="11,11,0,0" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <materialIcons:MaterialIcon x:Name="iconType" Kind="QuestionMarkCircle" 
                                                    Foreground="{StaticResource AccentBrush}" 
                                                    Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                                   FontWeight="Normal" FontSize="13" 
                                   Foreground="{StaticResource TextPrimary}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Área de arrastre nativa -->
                    <Rectangle Grid.Column="1" Fill="Transparent" IsHitTestVisible="True"/>

                    <!-- Botones HUD centralizados con fix de hitbox -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource HUDTitleBarMinimizeButtonStyle}" Click="MinimizeButton_Click">
                            <materialIcons:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="PART_Close" Style="{StaticResource HUDTitleBarCloseButtonStyle}" Click="btnNo_Click">
                            <materialIcons:MaterialIcon Kind="WindowClose" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Message Area -->
            <Grid Margin="24,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <materialIcons:MaterialIcon Kind="AlertCircleOutline" 
                                            Foreground="{StaticResource TextMuted}" 
                                            Width="32" Height="32" 
                                            VerticalAlignment="Top" 
                                            Margin="0,0,20,0"
                                            Opacity="0.5"/>

                <TextBlock Grid.Column="1" x:Name="textBlockMessage" 
                           TextWrapping="Wrap" 
                           Foreground="{StaticResource TextPrimary}" 
                           FontSize="13"
                           LineHeight="19"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 3. Footer Area -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" 
                    Padding="20,14" CornerRadius="0,0,11,11">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel x:Name="YesNoButtons" Orientation="Horizontal">
                        <Button x:Name="btnYes" Content="Yes" Style="{StaticResource SecondaryButton}" Click="btnYes_Click" Width="85" Height="32"/>
                        <Button x:Name="btnNoBottom" Content="No" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Click="btnNo_Click" Width="85" Height="32"/>
                    </StackPanel>
                    <Button x:Name="btnOk" Content="OK" Style="{StaticResource SecondaryButton}" Click="btnOk_Click" Visibility="Collapsed" Width="85" Height="32"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>