<base:HudWindow x:Class="AssetsManager.Views.Dialogs.ConfirmationDialog"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:local="clr-namespace:AssetsManager.Views.Dialogs"
                xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
                xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
                Width="440"
                SizeToContent="Height"
                WindowStartupLocation="CenterOwner" 
                Background="{StaticResource SidebarBackground}"
                Style="{StaticResource HudWindowStyle}"
                ShowMinimizeButton="False"
                ShowMaximizeButton="False"
                ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Message Area -->
        <Grid Grid.Row="0" Margin="24,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <materialIcons:MaterialIcon Kind="AlertCircleOutline" 
                                        Foreground="{StaticResource TextMuted}" 
                                        Width="32" Height="32" 
                                        VerticalAlignment="Top" 
                                        Margin="0,0,20,0"
                                        Opacity="0.5"/>

            <TextBlock Grid.Column="1" x:Name="textBlockMessage" 
                       TextWrapping="Wrap" 
                       Foreground="{StaticResource TextPrimary}" 
                       FontSize="13"
                       LineHeight="19"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- 2. Footer Area -->
        <Border Grid.Row="1" Background="{StaticResource CardBackground}" 
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" 
                Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <StackPanel x:Name="YesNoButtons" Orientation="Horizontal">
                    <Button x:Name="btnYes" Content="Yes" Style="{StaticResource SecondaryButton}" Click="btnYes_Click" Width="85" Height="32"/>
                    <Button x:Name="btnNoBottom" Content="No" Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Click="btnNo_Click" Width="85" Height="32"/>
                </StackPanel>
                <Button x:Name="btnOk" Content="OK" Style="{StaticResource SecondaryButton}" Click="btnOk_Click" Visibility="Collapsed" Width="85" Height="32"/>
            </StackPanel>
        </Border>
    </Grid>
</base:HudWindow>
