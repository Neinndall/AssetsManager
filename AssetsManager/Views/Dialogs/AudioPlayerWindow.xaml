<base:HudWindow x:Class="AssetsManager.Views.Dialogs.AudioPlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
        xmlns:audio="clr-namespace:AssetsManager.Services.Audio"
        mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
        Title="Audio Player" Height="600" Width="440"
        MinWidth="350" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SidebarBackground}"
        HeaderTitle="Audio Player"
        HeaderIcon="Waveform"
        Style="{StaticResource HudWindowStyle}"
        AllowDrop="True" Drop="Window_Drop">

    <Grid Background="{StaticResource SidebarBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- 0: Playlist Area -->
            <RowDefinition Height="Auto"/> <!-- 1: Player Controls -->
        </Grid.RowDefinitions>

        <!-- 1. Content Area (Playlist) -->
        <Grid Grid.Row="0" Margin="15">
            <!-- Empty State: Full Drop Area -->
            <Grid Visibility="{Binding Service.Playlist.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Invert}">
                <Rectangle x:Name="DropAreaUI" Stroke="{StaticResource BorderColor}" StrokeThickness="2" 
                           Fill="{StaticResource SidebarBackground}" RadiusX="10" RadiusY="10" 
                           StrokeDashArray="4 2"/>
                <Border Background="Transparent" CornerRadius="10"
                        DragEnter="DropArea_DragEnter" DragLeave="DropArea_DragLeave">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <icons:MaterialIcon Kind="Waveform" Width="60" Height="60" Foreground="{StaticResource TextMuted}" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                        <TextBlock Text="Drag and drop audio files" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Medium" HorizontalAlignment="Center"/>
                        <TextBlock Text="MP3 • WAV • OGG • YouTube URLs" Foreground="{StaticResource TextMuted}" FontSize="12" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Populated State: Playlist Area -->
            <Grid Visibility="{Binding Service.Playlist.Count, Converter={StaticResource CountToVisibilityConverter}}">
                <ListBox x:Name="PlaylistListBox" 
                         ItemsSource="{Binding Service.Playlist}"
                         Background="Transparent" BorderThickness="0"
                         ItemContainerStyle="{StaticResource ModernSelectableCardItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type audio:AudioPlaylistItem}">
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <icons:MaterialIcon Kind="MusicNote" Width="16" Height="16" Foreground="{StaticResource AccentBrush}" Opacity="0.7" Margin="0,0,10,0"/>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding AddedAt, StringFormat='Added: {0:HH:mm}'}" Foreground="{StaticResource TextMuted}" FontSize="10"/>
                                </StackPanel>

                                <Button Grid.Column="2" Style="{StaticResource TransparentIconButton}" Click="RemoveItem_Click" Tag="{Binding}">
                                    <icons:MaterialIcon Kind="TrashCanOutline" Width="14" Height="14" Foreground="{StaticResource AccentRed}"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>

        <!-- 2. Player Controls Area -->
        <Border Grid.Row="1" Background="{StaticResource CardBackground}" CornerRadius="0,0,11,11" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="24,20" ClipToBounds="True">
            <StackPanel>
                <!-- Row 1: Now Playing Info -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <icons:MaterialIcon Kind="MusicNote" Width="14" Height="14" Foreground="{StaticResource AccentBrush}" Opacity="0.7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="CurrentTrackName" Text="No track selected" 
                               Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="12" 
                               TextTrimming="CharacterEllipsis" MaxWidth="300" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Row 2: Timeline -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="45"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentTimeText" Text="0:00" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Slider x:Name="AudioSlider" Style="{StaticResource HUDSliderStyle}" Grid.Column="1" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" 
                            Thumb.DragStarted="AudioSlider_DragStarted" Thumb.DragCompleted="AudioSlider_DragCompleted" ValueChanged="AudioSlider_ValueChanged"/>
                    <TextBlock x:Name="TotalTimeText" Text="0:00" Grid.Column="2" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Row 3: Command Center -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> <!-- Utils Left -->
                        <ColumnDefinition Width="Auto"/> <!-- Main Buttons -->
                        <ColumnDefinition Width="*"/> <!-- Utils Right -->
                    </Grid.ColumnDefinitions>

                    <!-- Secondary: Add URL -->
                    <Button HorizontalAlignment="Left" Style="{StaticResource TransparentIconButton}" Click="AddUrl_Click" ToolTip="Add URL" Width="34" Height="34">
                        <icons:MaterialIcon Kind="Link" Width="20" Height="20" Foreground="{StaticResource AccentBrush}"/>
                    </Button>

                    <!-- Primary: Playback -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource IconButton}" Background="White" Width="38" Height="38" Click="SkipBackward_Click">
                            <icons:MaterialIcon Kind="SkipPrevious" Width="20" Height="20" Foreground="{StaticResource SidebarBackground}"/>
                        </Button>
                        
                        <Button x:Name="PlayPauseButton" Style="{StaticResource PrimaryButton}" Width="38" Height="38" Margin="15,0" Click="PlayPause_Click">
                            <icons:MaterialIcon Kind="{Binding IsPlaying, Converter={StaticResource BooleanToMaterialIconConverter}, ConverterParameter='Pause,Play'}" Width="20" Height="20"/>
                        </Button>
                        
                        <Button Style="{StaticResource IconButton}" Background="White" Width="38" Height="38" Click="SkipForward_Click">
                            <icons:MaterialIcon Kind="SkipNext" Width="20" Height="20" Foreground="{StaticResource SidebarBackground}"/>
                        </Button>
                    </StackPanel>
                    
                    <!-- Secondary: Clear -->
                    <Button Grid.Column="2" HorizontalAlignment="Right" Style="{StaticResource TransparentIconButton}" Click="ClearPlaylist_Click" ToolTip="Clear Playlist" Width="34" Height="34">
                        <icons:MaterialIcon Kind="DeleteSweepOutline" Width="20" Height="20" Foreground="{StaticResource TextMuted}"/>
                    </Button>
                </Grid>

                <!-- Row 4: Volume -->
                <Border Background="{StaticResource SidebarBackground}" CornerRadius="15" Padding="12,4" Margin="0,20,0,0" HorizontalAlignment="Center" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <icons:MaterialIcon Kind="{Binding IsMuted, Converter={StaticResource BooleanToMaterialIconConverter}, ConverterParameter='VolumeMute,VolumeMedium'}" 
                                            Width="14" Height="14" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider x:Name="VolumeSlider" Style="{StaticResource HUDSliderStyle}" Width="120" Minimum="0" Maximum="1" Value="{Binding Volume}" VerticalAlignment="Center" ValueChanged="VolumeSlider_ValueChanged"/>
                        <TextBlock Text="{Binding Value, ElementName=VolumeSlider, StringFormat={}{0:P0}}" 
                                   FontSize="9" FontWeight="Bold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="10,0,0,0" Width="30"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</base:HudWindow>