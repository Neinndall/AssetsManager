<base:HudWindow x:Class="AssetsManager.Views.Dialogs.InputDialog"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:local="clr-namespace:AssetsManager.Views.Dialogs"
                xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
                xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
                mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
                Width="480"
                SizeToContent="Height"
                WindowStartupLocation="CenterOwner" 
                Background="{StaticResource SidebarBackground}"
                Style="{StaticResource HudWindowStyle}"
                ShowMinimizeButton="False"
                ShowMaximizeButton="False"
                ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Content Area (Input Section) -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}" Padding="24,24">
            <StackPanel>
                <TextBlock Name="textBlockQuestion" 
                           TextWrapping="Wrap" 
                           Margin="0,0,0,16" 
                           Foreground="{StaticResource TextSecondary}" 
                           FontSize="12"/>
                               
                <TextBox Name="textBoxInput" 
                         Style="{StaticResource ModernTextBoxEditable}" 
                         AcceptsReturn="True" 
                         TextWrapping="Wrap" 
                         VerticalScrollBarVisibility="Auto" 
                         MinHeight="44" MaxHeight="250"
                         FontSize="12"
                         Padding="12"/>
            </StackPanel>
        </Border>

        <!-- 2. Footer Area -->
        <Border Grid.Row="1" Background="{StaticResource CardBackground}" 
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" 
                Padding="20,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="btnCancelBottom" Content="Cancel" Click="btnCancel_Click" Style="{StaticResource SecondaryButton}" Width="90" Height="32"/>
                <Button Name="btnOk" Content="OK" Margin="12,0,0,0" Click="btnOk_Click" Style="{StaticResource SecondaryButton}" Width="90" Height="32"/>
            </StackPanel>
        </Border>
    </Grid>
</base:HudWindow>
