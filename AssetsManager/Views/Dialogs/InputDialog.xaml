<Window x:Class="AssetsManager.Views.Dialogs.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:AssetsManager.Views.Dialogs"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
        Title="Input" Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner" 
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <!-- Margen para la sombra HUD -->
    <Border Margin="10" Background="{StaticResource SidebarBackground}" 
            BorderBrush="{StaticResource BorderColor}" BorderThickness="1" 
            CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.4"/>
        </Border.Effect>
        
        <StackPanel>
            <!-- 1. Header Area (HUD Style 36px) -->
            <Border Height="36" Background="{StaticResource CardBackground}" 
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1"
                    CornerRadius="11,11,0,0" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                        <materialIcons:MaterialIcon Kind="TextBoxEdit" 
                                                    Foreground="{StaticResource AccentBrush}" 
                                                    Width="16" Height="16" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                                   FontWeight="Normal" FontSize="13" 
                                   Foreground="{StaticResource TextPrimary}" 
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Área de arrastre -->
                    <Rectangle Grid.Column="1" Fill="Transparent" IsHitTestVisible="True" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

                    <!-- Botones HUD centralizados -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource HUDTitleBarMinimizeButtonStyle}" Click="MinimizeButton_Click">
                            <materialIcons:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="PART_Close" Style="{StaticResource HUDTitleBarCloseButtonStyle}" Click="btnCancel_Click">
                            <materialIcons:MaterialIcon Kind="WindowClose" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Content Area (Input Section) -->
            <Border Background="{StaticResource SidebarBackground}" Padding="24,24">
                <StackPanel>
                    <TextBlock Name="textBlockQuestion" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,16" 
                               Foreground="{StaticResource TextSecondary}" 
                               FontSize="12"/>
                                   
                    <TextBox Name="textBoxInput" 
                             Style="{StaticResource ModernTextBoxEditable}" 
                             AcceptsReturn="True" 
                             TextWrapping="Wrap" 
                             VerticalScrollBarVisibility="Auto" 
                             MinHeight="44" MaxHeight="250"
                             FontSize="12"
                             Padding="12"/>
                </StackPanel>
            </Border>

            <!-- 3. Footer Area -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" 
                    Padding="20,14" CornerRadius="0,0,11,11">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Name="btnCancelBottom" Content="Cancel" Click="btnCancel_Click" Style="{StaticResource SecondaryButton}" Width="90" Height="32"/>
                    <Button Name="btnOk" Content="OK" Margin="12,0,0,0" Click="btnOk_Click" Style="{StaticResource SecondaryButton}" Width="90" Height="32"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>