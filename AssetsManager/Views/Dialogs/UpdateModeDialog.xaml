<Window x:Class="AssetsManager.Views.Dialogs.UpdateModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        mc:Ignorable="d" FontFamily="{StaticResource AppFontFamily}"
        Title="Update Mode" Height="Auto" Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" 
                      ResizeBorderThickness="8" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
        
    <Border Margin="10" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Background="{StaticResource SidebarBackground}">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="Black" Opacity="0.4"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: Custom Title Bar -->
                <RowDefinition Height="*"/>    <!-- 1: Body (Info & Options) -->
                <RowDefinition Height="Auto"/> <!-- 2: Footer Area -->
            </Grid.RowDefinitions>

            <!-- 1. Custom Title Bar (HUD Style: 36px) -->
            <Border Grid.Row="0" Background="{StaticResource CardBackground}" Height="36" CornerRadius="11,11,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Panel.ZIndex="10" ClipToBounds="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/> <!-- Icon/Title -->
                        <ColumnDefinition Width="*"/>    <!-- Spacer -->
                        <ColumnDefinition Width="Auto"/> <!-- Window Controls -->
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                        <materialIcons:MaterialIcon Kind="Update" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Update Selection" FontWeight="Normal" FontSize="13" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Rectangle Grid.Column="1" Fill="Transparent" IsHitTestVisible="True"/>

                    <!-- HUD Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource HUDTitleBarMinimizeButtonStyle}" Click="MinimizeButton_Click">
                            <materialIcons:MaterialIcon Kind="WindowMinimize" Width="14" Height="14"/>
                        </Button>
                        <Button x:Name="PART_Close" Style="{StaticResource HUDTitleBarCloseButtonStyle}" Click="CancelButton_Click">
                            <materialIcons:MaterialIcon Kind="WindowClose" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. Body Area (SidebarBackground) -->
            <StackPanel Grid.Row="1" Margin="24">
                <TextBlock Text="Update Available" Foreground="{StaticResource TextPrimary}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock Text="A new version is ready to be installed. Please choose your preferred installation method below to proceed." 
                           Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,24"/>
                
                <!-- Option Cards -->
                <!-- Option 1: Save Settings -->
                <Button x:Name="CleanUpdateWithSaveButton" 
                        Style="{StaticResource SecondaryButton}" 
                        Background="{StaticResource CardBackground}"
                        Margin="0,0,0,12" 
                        Click="CleanUpdateWithSaveButton_Click" 
                        Height="Auto" 
                        HorizontalContentAlignment="Stretch" 
                        Padding="16"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" Background="{StaticResource SidebarBackground}" CornerRadius="20" Margin="0,0,16,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <materialIcons:MaterialIcon Kind="CloudDownloadOutline" Width="20" Height="20" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Standard Update (Recommended)" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Preserves your settings and configurations." FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
                
                <!-- Option 2: Fresh Install -->
                <Button x:Name="CleanUpdateNoSaveButton" 
                        Style="{StaticResource SecondaryButton}" 
                        Background="{StaticResource CardBackground}"
                        Click="CleanUpdateNoSaveButton_Click" 
                        Height="Auto" 
                        HorizontalContentAlignment="Stretch" 
                        Padding="16"
                        BorderThickness="1">
                     <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="40" Height="40" Background="{StaticResource SidebarBackground}" CornerRadius="20" Margin="0,0,16,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <materialIcons:MaterialIcon Kind="DeleteRestore" Width="20" Height="20" Foreground="{StaticResource AccentRed}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Fresh Install" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Resets all local settings to factory defaults." FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Button>
            </StackPanel>

            <!-- 3. Footer Area (CardBackground) -->
            <Border Grid.Row="2" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" 
                    Padding="20,14" CornerRadius="0,0,11,11">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                     <Button x:Name="CancelButton" Content="Cancel" Style="{StaticResource SecondaryButton}" Click="CancelButton_Click" Width="100" Height="32"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>