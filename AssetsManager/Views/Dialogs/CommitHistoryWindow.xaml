<base:HudWindow x:Class="AssetsManager.Views.Dialogs.CommitHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
        mc:Ignorable="d"
        Height="650" Width="850"
        MinHeight="650" MinWidth="850"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SidebarBackground}"
        HeaderTitle="Commit History" 
        HeaderIcon="Update"
        Style="{StaticResource HudWindowStyle}"
        FontFamily="{StaticResource AppFontFamily}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR: REVISION DASHBOARD -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}" Padding="32,28,32,24" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource CardBackground}" CornerRadius="12" Width="52" Height="52" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <materialIcons:MaterialIcon Kind="SourceBranch" Width="28" Height="28" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="QA BRANCH" FontWeight="Black" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="0,0,12,0"/>
                            <Border Background="{StaticResource HoverColor}" CornerRadius="6" Padding="8,2" VerticalAlignment="Center">
                                <TextBlock Text="LIVE TRACKING" FontSize="9" FontWeight="Black" Foreground="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Current Version: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentVersion}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <Rectangle Width="1" Height="10" Fill="{StaticResource BorderColor}" Margin="12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Total Commits: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Commits.Count}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnRefresh" 
                            Style="{StaticResource SecondaryButton}" 
                            Height="36" Padding="20,0" 
                            Click="BtnRefresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialIcons:MaterialIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="REFRESH" VerticalAlignment="Center" FontSize="11" FontWeight="Black"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT: TIMELINE -->
        <Grid Grid.Row="1">
            <!-- Loading Indicator -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <materialIcons:MaterialIcon Kind="Sync" Width="48" Height="48" Foreground="{StaticResource AccentBrush}" RenderTransformOrigin="0.5,0.5">
                    <materialIcons:MaterialIcon.RenderTransform>
                        <RotateTransform Angle="0" x:Name="SpinnerRotate"/>
                    </materialIcons:MaterialIcon.RenderTransform>
                    <materialIcons:MaterialIcon.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </materialIcons:MaterialIcon.Triggers>
                </materialIcons:MaterialIcon>
                <TextBlock Text="Synchronizing QA builds..." FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Commits List with GitHub Timeline Style -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24" Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <Grid>
                    <!-- Timeline Vertical Line -->
                    <Border HorizontalAlignment="Left" Width="2" Background="{StaticResource BorderColor}" Margin="13,32,0,0" Opacity="0.5"/>
                    
                    <ItemsControl ItemsSource="{Binding GroupedCommits}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,16">
                                    <!-- Date Header -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="28"/> <!-- Standardized Timeline Column -->
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <materialIcons:MaterialIcon Grid.Column="0" Kind="SourceCommit" Width="18" Height="18" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DateHeader}" FontWeight="Black" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>

                                    <!-- Commits in this group -->
                                    <ItemsControl ItemsSource="{Binding Commits}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28"/> <!-- Standardized Timeline Column -->
                                                        <ColumnDefinition Width="*"/>    <!-- Content -->
                                                        <ColumnDefinition Width="Auto"/> <!-- Actions -->
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Connection Dot -->
                                                    <Border Grid.Column="0" Width="8" Height="8" CornerRadius="4" 
                                                            Background="{StaticResource ResourceKey=BorderColor}" 
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Top" Margin="0,16,0,0" Panel.ZIndex="5">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>

                                                    <!-- Main Vertical Content Stack -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="8,2,0,0">
                                                        <!-- Line 1: Title and Status -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding MessageSummary}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap" MaxWidth="500"/>
                                                            
                                                            <!-- GitHub Style Expand Button (...) -->
                                                            <ToggleButton x:Name="BtnExpand" 
                                                                          Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                          Margin="10,0,0,0" VerticalAlignment="Center"
                                                                          Cursor="Hand">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border x:Name="BtnBorder"
                                                                                Background="{StaticResource SidebarBackground}" 
                                                                                BorderBrush="{StaticResource BorderColor}" 
                                                                                BorderThickness="1.5" 
                                                                                CornerRadius="4" 
                                                                                Padding="5,0,5,1.5" 
                                                                                Height="16">
                                                                            <TextBlock Text="..." FontSize="11" FontWeight="Black" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource HoverColor}"/>
                                                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource HoverColor}"/>
                                                                                <Setter TargetName="BtnBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                        </StackPanel>

                                                        <!-- Line 2: Collapsible Description -->
                                                        <TextBlock Text="{Binding MessageBody}" 
                                                                   Visibility="{Binding IsChecked, ElementName=BtnExpand, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                   FontSize="12" Foreground="{StaticResource TextMuted}" 
                                                                   Margin="0,8,0,0" TextWrapping="Wrap" MaxWidth="540" 
                                                                   LineHeight="18" FontFamily="Consolas" Opacity="0.8"
                                                                   TextAlignment="Left"/>

                                                        <!-- Line 3: Author Metadata Line -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <!-- Small Avatar Icon -->
                                                            <Border Width="18" Height="18" CornerRadius="9" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,8,0" VerticalAlignment="Center" ClipToBounds="True">
                                                                <Grid>
                                                                    <materialIcons:MaterialIcon Kind="Account" Width="10" Height="10" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <Image Source="{Binding Author.AvatarUrl}" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                                </Grid>
                                                            </Border>
                                                            
                                                            <TextBlock Text="{Binding Commit.Author.Name}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                                            <TextBlock Text=" committed " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Commit.Author.Date, Converter={StaticResource TimeAgoConverter}}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>

                                                            <Border Background="{StaticResource SidebarBackground}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding ShortSha}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" FontFamily="Consolas"/>
                                                            </Border>

                                                            <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsLatest, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="LATEST" FontSize="8" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Margin="0,-0.5,0,0"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Actions (Aligned to Right) -->
                                                    <Grid Grid.Column="2" VerticalAlignment="Top" Margin="24,0,0,0">
                                                        <!-- 1. Direct Install -->
                                                        <Button Style="{StaticResource PrimaryButton}"
                                                                Height="32" Padding="14,0"
                                                                Click="BtnDownload_Click"
                                                                Visibility="{Binding DownloadableAsset, Converter={StaticResource NullToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialIcons:MaterialIcon Kind="CloudDownloadOutline" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                                                                <TextBlock Text="INSTALL" VerticalAlignment="Center" FontSize="10" FontWeight="Black"/>
                                                            </StackPanel>
                                                        </Button>

                                                        <!-- 2. Inherited Build -->
                                                        <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Height="32" Padding="14,0" Visibility="{Binding HasInheritedBuild, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialIcons:MaterialIcon Kind="PackageVariantClosed" Width="14" Height="14" Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding ParentBuildSha}" FontSize="10" FontWeight="Black" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- 3. Orphaned (No Build) -->
                                                        <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="6" Height="32" Padding="14,0" Opacity="0.5">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <MultiDataTrigger>
                                                                            <MultiDataTrigger.Conditions>
                                                                                <Condition Binding="{Binding DownloadableAsset, Converter={StaticResource NullToVisibilityConverter}}" Value="Collapsed"/>
                                                                                <Condition Binding="{Binding HasInheritedBuild}" Value="False"/>
                                                                            </MultiDataTrigger.Conditions>
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </MultiDataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <materialIcons:MaterialIcon Kind="CloudOffOutline" Width="14" Height="14" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                                <TextBlock Text="NO BUILD" FontSize="10" FontWeight="Black" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>                                
                                               </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- FOOTER: TECHNICAL STATUS -->
        <Border Grid.Row="2" Background="{StaticResource CardBackground}" Padding="32,16" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="Github" Width="16" Height="16" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="GITHUB QA REPOSITORY" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Margin="10,1,0,0" Opacity="0.9"/>
                    <Rectangle Width="1" Height="12" Fill="{StaticResource BorderColor}" Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,1,0,0" Opacity="0.7"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="InformationOutline" Width="14" Height="14" Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Development builds may be unstable." Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</base:HudWindow>
