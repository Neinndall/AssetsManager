<base:HudWindow x:Class="AssetsManager.Views.Dialogs.CommitHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
        xmlns:base="clr-namespace:AssetsManager.Views.Helpers"
        mc:Ignorable="d"
        Height="650" Width="850"
        MinHeight="650" MinWidth="850"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource SidebarBackground}"
        HeaderTitle="Commit History" 
        HeaderIcon="Update"
        Style="{StaticResource HudWindowStyle}"
        FontFamily="{StaticResource AppFontFamily}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR: REVISION DASHBOARD -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}" Padding="32,28,32,24" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource CardBackground}" CornerRadius="12" Width="52" Height="52" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <materialIcons:MaterialIcon Kind="SourceBranch" Width="28" Height="28" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="18,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="QA BRANCH" FontWeight="Black" FontSize="14" Foreground="{StaticResource TextPrimary}" Margin="0,0,12,0"/>
                            <Border Background="{StaticResource HoverColor}" CornerRadius="6" Padding="8,2" VerticalAlignment="Center">
                                <TextBlock Text="LIVE TRACKING" FontSize="9" FontWeight="Black" Foreground="{StaticResource AccentGreen}" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Current Version: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding CurrentVersion}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <Rectangle Width="1" Height="10" Fill="{StaticResource BorderColor}" Margin="12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Total Commits: " FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock Text="{Binding Commits.Count}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnRefresh" 
                            Style="{StaticResource SecondaryButton}" 
                            Height="36" Padding="20,0" 
                            Click="BtnRefresh_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialIcons:MaterialIcon Kind="Refresh" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="REFRESH" VerticalAlignment="Center" FontSize="11" FontWeight="Black"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT: TIMELINE -->
        <Grid Grid.Row="1">
            <!-- Loading Indicator -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                <materialIcons:MaterialIcon Kind="Sync" Width="48" Height="48" Foreground="{StaticResource AccentBrush}" RenderTransformOrigin="0.5,0.5">
                    <materialIcons:MaterialIcon.RenderTransform>
                        <RotateTransform Angle="0" x:Name="SpinnerRotate"/>
                    </materialIcons:MaterialIcon.RenderTransform>
                    <materialIcons:MaterialIcon.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1.5" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </materialIcons:MaterialIcon.Triggers>
                </materialIcons:MaterialIcon>
                <TextBlock Text="Synchronizing QA builds..." FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" Margin="0,12,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Commits List with Timeline Style -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,16" Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <Grid>
                    <!-- Timeline Vertical Line -->
                    <Border HorizontalAlignment="Left" Width="2" Background="{StaticResource BorderColor}" Margin="49,0,0,0" Opacity="0.5"/>
                    
                    <ItemsControl ItemsSource="{Binding Commits}" Margin="32,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/> <!-- Timeline Hub -->
                                        <ColumnDefinition Width="*"/>  <!-- Content -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Timeline Node -->
                                    <Border Grid.Column="0" Width="12" Height="12" CornerRadius="6" 
                                            Background="{StaticResource SidebarBackground}" 
                                            BorderBrush="{StaticResource BorderColor}" 
                                            BorderThickness="2" 
                                            VerticalAlignment="Top" Margin="0,12,0,0" Panel.ZIndex="5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLatest}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Revision Card -->
                                    <Border Grid.Column="1" Style="{StaticResource SettingsCard}" Margin="20,0,0,0" Padding="24,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Author Avatar -->
                                            <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21" BorderBrush="{StaticResource BorderColor}" BorderThickness="1.5" Margin="0,0,20,0" VerticalAlignment="Top" ClipToBounds="True">
                                                <Grid>
                                                    <!-- Initial Placeholder -->
                                                    <materialIcons:MaterialIcon Kind="Account" Width="24" Height="24" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <!-- Real GitHub Avatar -->
                                                    <Image Source="{Binding Author.AvatarUrl}" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Grid>
                                            </Border>

                                            <!-- Revision Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Commit.Author.Name}" FontWeight="Black" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                                                    <Border Background="{StaticResource SidebarBackground}" CornerRadius="4" Padding="8,2" Margin="10,0,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                                        <TextBlock Text="{Binding ShortSha}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" FontFamily="Consolas"/>
                                                    </Border>
                                                    <Border Background="{StaticResource AccentBrush}" CornerRadius="4" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsLatest, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <TextBlock Text="LATEST" FontSize="9" FontWeight="Black" Foreground="White" VerticalAlignment="Center" Margin="0,-0.5,0,0"/>
                                                    </Border>
                                                </StackPanel>
                                                
                                                <TextBlock Text="{Binding Commit.Message}" FontSize="13" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0" TextWrapping="Wrap" LineHeight="20"/>
                                                
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Opacity="0.6">
                                                    <materialIcons:MaterialIcon Kind="ClockOutline" Width="12" Height="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Commit.Author.Date, StringFormat='{}Committed {0:MMM dd, yyyy HH:mm}'}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Actions -->
                                            <Grid Grid.Column="2" VerticalAlignment="Center" Margin="24,0,0,0">
                                                <!-- 1. Direct Install -->
                                                <Button x:Name="BtnDownload"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Height="34" Padding="12,0"
                                                        Click="BtnDownload_Click"
                                                        Visibility="{Binding DownloadableAsset, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialIcons:MaterialIcon Kind="CloudDownloadOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="White"/>
                                                        <TextBlock Text="INSTALL" VerticalAlignment="Center" FontSize="11" FontWeight="Black"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- 2. Inherited Build -->
                                                <Border Background="{StaticResource HoverColor}" CornerRadius="8" Padding="12,8" Visibility="{Binding HasInheritedBuild, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialIcons:MaterialIcon Kind="PackageVariantClosed" Width="16" Height="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <StackPanel>
                                                            <TextBlock Text="INHERITED BUILD" FontSize="10" FontWeight="Black" Foreground="{StaticResource AccentBrush}"/>
                                                            <TextBlock Text="{Binding ParentBuildSha, StringFormat='{}Revision {0}'}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>

                                                <!-- 3. Orphaned (No Build) -->
                                                <Border Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8" Padding="12,8" Opacity="0.5">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding DownloadableAsset, Converter={StaticResource NullToVisibilityConverter}}" Value="Collapsed"/>
                                                                        <Condition Binding="{Binding HasInheritedBuild}" Value="False"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialIcons:MaterialIcon Kind="CloudOffOutline" Width="16" Height="16" Foreground="{StaticResource TextMuted}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="NO BUILD FOUND" FontSize="10" FontWeight="Black" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>                                
                                       </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- FOOTER: TECHNICAL STATUS -->
        <Border Grid.Row="2" Background="{StaticResource CardBackground}" Padding="32,16" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="Github" Width="16" Height="16" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Opacity="0.8"/>
                    <TextBlock Text="GITHUB QA REPOSITORY" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Margin="10,1,0,0" Opacity="0.9"/>
                    <Rectangle Width="1" Height="12" Fill="{StaticResource BorderColor}" Margin="16,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,1,0,0" Opacity="0.7"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="InformationOutline" Width="14" Height="14" Foreground="{StaticResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Development builds may be unstable." Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</base:HudWindow>
