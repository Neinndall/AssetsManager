<UserControl x:Class="AssetsManager.Views.Dialogs.Controls.WadComparisonGalleryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:converters="clr-namespace:AssetsManager.Views.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:ChunkDiffTypeToBrushConverter x:Key="DiffToBrushConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Gallery Header & Tools -->
            <Border Grid.Row="0" Margin="0,0,0,24">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="VISUAL DISCOVERY" Style="{StaticResource ToolSectionLabel}" Margin="0,0,24,0" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="12,6" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <materialIcons:MaterialIcon Kind="ImageMultiple" Width="14" Height="14" Foreground="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DiscoveryItems.Count, StringFormat='{}{0} visual assets found'}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- Future: Category Filters here -->
                </StackPanel>
            </Grid>
        </Border>

        <!-- Discovery Grid -->
        <ListBox Grid.Row="1" 
                 ItemsSource="{Binding DiscoveryItems}" 
                 Style="{StaticResource ModernFileGridListBox}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 SelectionMode="Extended">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Width="160" Margin="4">
                        <Border x:Name="SelectionBorder" Background="{StaticResource CardBackground}" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Padding="8">
                             <StackPanel>
                                <!-- Thumbnail (using existing TextureUtils logic or direct Binding) -->
                                <Border Background="{StaticResource SidebarBackground}" Height="120" CornerRadius="8" Margin="0,0,0,10" ClipToBounds="True" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                    <Grid>
                                        <!-- Placeholder/Loading Icon -->
                                        <materialIcons:MaterialIcon Kind="ImageOutline" Width="32" Height="32" Foreground="{StaticResource TextMuted}" Opacity="0.3" 
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                    Visibility="{Binding ImagePreview, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}"/>
                                        
                                        <!-- Real Image Preview -->
                                        <Border CornerRadius="8" Visibility="{Binding ImagePreview, Converter={StaticResource NullToVisibilityConverter}}">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ImagePreview}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <!-- Status Badge -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6" Padding="6,2" CornerRadius="4" 
                                                Background="{Binding Type, Converter={StaticResource DiffToBrushConverter}}">
                                            <TextBlock Text="{Binding Type}" FontSize="9" FontWeight="Black" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <TextBlock Text="{Binding FileName}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Path}" FontSize="9" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" Opacity="0.7" HorizontalAlignment="Center"/>
                             </StackPanel>
                        </Border>
                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                            <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="SelectionBorder" Property="BorderThickness" Value="2"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
    </Border>
</UserControl>
