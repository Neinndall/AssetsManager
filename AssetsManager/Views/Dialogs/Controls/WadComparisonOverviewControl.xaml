<UserControl x:Class="AssetsManager.Views.Dialogs.Controls.WadComparisonOverviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:icons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel>
            <!-- 1. HERO SUMMARY CARD -->
            <Border Background="{StaticResource CardBackground}" CornerRadius="16" Padding="32" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,32">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Background="{StaticResource SidebarBackground}" Width="64" Height="64" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <icons:MaterialIcon Kind="AutoFix" Width="32" Height="32" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="PATCH INTELLIGENCE SUMMARY" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding SummaryText}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 2. CATEGORY DISTRIBUTION -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="ASSET DISTRIBUTION" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding TreeModel.CategoryDistribution}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                        <Grid Margin="0,0,0,8">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{StaticResource TextPrimary}" FontWeight="Black"/>
                                                <TextBlock Text="{Binding SizeChangeText}" FontSize="11" Foreground="{StaticResource AccentBrush}" Margin="10,0,0,0" VerticalAlignment="Bottom" Opacity="0.8"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Count, StringFormat='{}{0} files'}" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                        </Grid>
                                        <ProgressBar Grid.Row="1" Height="6" Value="{Binding Percentage}" Foreground="{StaticResource AccentBrush}" Background="{StaticResource SidebarBackground}" BorderThickness="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- 3. TOP IMPACT & AREAS -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="CRITICAL SIZE IMPACT" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,16"/>
                    <ItemsControl ItemsSource="{Binding TreeModel.TopImpactFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBackground}" CornerRadius="12" Padding="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="Black" Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Path}" FontSize="10" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis" Opacity="0.7"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding SizeDiffText}" FontSize="12" FontWeight="Black" Foreground="{StaticResource AccentOrange}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="AFFECTED GAME AREAS" Style="{StaticResource ToolSectionLabel}" Margin="0,20,0,16"/>
                    <ItemsControl ItemsSource="{Binding TreeModel.AffectedAreas}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="12,8" Margin="0,0,8,8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Black" Foreground="{StaticResource TextSecondary}"/>
                                        <Border Background="{StaticResource SidebarBackground}" CornerRadius="6" Margin="10,0,0,0" Padding="6,2">
                                            <TextBlock Text="{Binding Count}" FontSize="10" Foreground="{StaticResource AccentBrush}" FontWeight="Black"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
