<UserControl x:Class="AssetsManager.Views.StatsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AssetsManager.Views"
             xmlns:shared="clr-namespace:AssetsManager.Views.Controls.Shared"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="1200"
             FontFamily="{StaticResource AppFontFamily}"
             Loaded="UserControl_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- 0. HERO HEADER -->
        <Border Grid.Row="0" Margin="32,24,32,16" Background="{StaticResource CardBackground}" CornerRadius="16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Border.Effect><DropShadowEffect BlurRadius="30" ShadowDepth="2" Opacity="0.2" Color="Black"/></Border.Effect>
            <Border Padding="24,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" CornerRadius="12" Width="56" Height="56">
                        <materialIcons:MaterialIcon Kind="Sword" Width="30" Height="30" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <materialIcons:MaterialIcon.Effect><DropShadowEffect Color="#FF5C85FF" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/></materialIcons:MaterialIcon.Effect>
                        </materialIcons:MaterialIcon>
                    </Border>
                    <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BorderColor}" Margin="20,10" VerticalAlignment="Stretch" Opacity="0.6"/>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="CHAMPION ANALYTICS ENGINE" FontWeight="SemiBold" FontSize="22" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,2"/>
                        <TextBlock Text="Full spectrum extraction: Stats, Resources, Lore, and Deep Spell Mechanics" FontSize="12" Foreground="{StaticResource TextSecondary}" Opacity="0.8"/>
                    </StackPanel>
                    <shared:SearchBoxControl Grid.Column="3" Width="280" Tag="Search database..." Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Border>
        </Border>

        <!-- 1. MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="32,0,32,32">
            <Grid.ColumnDefinitions><ColumnDefinition Width="300"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <!-- Sidebar: List -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,16,0">
                <Grid>
                    <ListBox ItemsSource="{Binding Champions}" SelectedItem="{Binding SelectedChampion}" Background="Transparent" BorderThickness="0" Padding="12" ItemContainerStyle="{StaticResource ModernSelectableCardItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="36" Height="36" Background="{StaticResource SidebarBackground}" CornerRadius="18" ClipToBounds="True">
                                        <Image Source="{Binding IconSource}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding Roles}" FontSize="10" Foreground="{StaticResource AccentBrush}" Opacity="0.8"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Border Background="{StaticResource SidebarBackground}" Opacity="0.9" CornerRadius="12" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="Sync" Width="48" Height="48" Foreground="{StaticResource AccentBrush}" Style="{StaticResource SpinningIconStyle}" Margin="0,0,0,16"/>
                            <TextBlock Text="CRAWLING GAME DATA..." Foreground="{StaticResource TextPrimary}" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Panel -->
            <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding SelectedChampion, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}">
                        <materialIcons:MaterialIcon Kind="Search" Width="64" Height="64" Foreground="{StaticResource TextMuted}" Opacity="0.2"/>
                        <TextBlock Text="Select a champion for deep technical analysis" Foreground="{StaticResource TextMuted}" Margin="0,16,0,0" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding SelectedChampion, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel Margin="32">
                            <!-- Hero Title -->
                            <Grid Margin="0,0,0,32">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="96" Height="96" CornerRadius="48" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2" Padding="4" Margin="0,0,24,0">
                                    <Border CornerRadius="44" ClipToBounds="True">
                                        <Image Source="{Binding SelectedChampion.IconSource}" Stretch="UniformToFill"/>
                                    </Border>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedChampion.Name}" FontSize="48" FontWeight="Black" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="{Binding SelectedChampion.Roles, StringFormat='{}ROLES: {0}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Grid>

                            <!-- TECHNICAL RANKINGS -->
                            <TextBlock Text="TECHNICAL RANKINGS" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,16"/>
                            <UniformGrid Columns="4" Margin="0,0,0,32">
                                <StackPanel Margin="0,0,12,0"><TextBlock Text="ATTACK" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/><ProgressBar Value="{Binding SelectedChampion.AttackRank}" Maximum="10" Height="4" Margin="0,6,0,0" Foreground="{StaticResource AccentBrush}" Background="{StaticResource SidebarBackground}"/></StackPanel>
                                <StackPanel Margin="0,0,12,0"><TextBlock Text="DEFENSE" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/><ProgressBar Value="{Binding SelectedChampion.DefenseRank}" Maximum="10" Height="4" Margin="0,6,0,0" Foreground="#FFFF4B4B" Background="{StaticResource SidebarBackground}"/></StackPanel>
                                <StackPanel Margin="0,0,12,0"><TextBlock Text="MAGIC" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/><ProgressBar Value="{Binding SelectedChampion.MagicRank}" Maximum="10" Height="4" Margin="0,6,0,0" Foreground="#FF4B8BFF" Background="{StaticResource SidebarBackground}"/></StackPanel>
                                <StackPanel><TextBlock Text="DIFFICULTY" FontSize="10" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/><ProgressBar Value="{Binding SelectedChampion.DifficultyRank}" Maximum="10" Height="4" Margin="0,6,0,0" Foreground="#FFAA4BFF" Background="{StaticResource SidebarBackground}"/></StackPanel>
                            </UniformGrid>

                            <!-- ULTRA-DETAILED COMBAT METRICS -->
                            <TextBlock Text="ULTRA-DETAILED COMBAT METRICS" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,16"/>
                            <Border Background="{StaticResource SidebarBackground}" CornerRadius="12" Padding="24" Margin="0,0,0,32" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <UniformGrid Columns="3">
                                    <!-- Health -->
                                    <StackPanel Margin="0,0,24,24">
                                        <TextBlock Text="HEALTH" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="18">
                                            <Run Text="{Binding SelectedChampion.BaseHP, StringFormat='{}{0:F0}'}" FontWeight="Bold"/>
                                            <Run Text="{Binding SelectedChampion.HPPerLevel, StringFormat='{} (+{0:F0})'}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                            <Run Text="Regen: "/><Run Text="{Binding SelectedChampion.BaseHPRegen, StringFormat='{}{0:F1}'}"/><Run Text="{Binding SelectedChampion.HPRegenPerLevel, StringFormat='{} (+{0:F2})'}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Armor -->
                                    <StackPanel Margin="0,0,24,24">
                                        <TextBlock Text="ARMOR" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="18">
                                            <Run Text="{Binding SelectedChampion.BaseArmor, StringFormat='{}{0:F0}'}" FontWeight="Bold"/>
                                            <Run Text="{Binding SelectedChampion.ArmorPerLevel, StringFormat='{} (+{0:F1})'}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- MR -->
                                    <StackPanel Margin="0,0,0,24">
                                        <TextBlock Text="MAGIC RESIST" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="18">
                                            <Run Text="{Binding SelectedChampion.BaseMR, StringFormat='{}{0:F0}'}" FontWeight="Bold"/>
                                            <Run Text="{Binding SelectedChampion.MRPerLevel, StringFormat='{} (+{0:F1})'}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- AD -->
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="ATTACK DAMAGE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="18">
                                            <Run Text="{Binding SelectedChampion.BaseDamage, StringFormat='{}{0:F0}'}" FontWeight="Bold"/>
                                            <Run Text="{Binding SelectedChampion.DamagePerLevel, StringFormat='{} (+{0:F0})'}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                            <Run Text="Adaptive AP: "/><Run Text="{Binding SelectedChampion.AdaptiveForceToAPWeight, StringFormat='{}{0:F1}'}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Attack Speed -->
                                    <StackPanel Margin="0,0,24,0">
                                        <TextBlock Text="ATTACK SPEED" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="18">
                                            <Run Text="{Binding SelectedChampion.BaseAttackSpeed, StringFormat='{}{0:F3}'}" FontWeight="Bold"/>
                                            <Run Text="{Binding SelectedChampion.AttackSpeedPerLevel, StringFormat='{} ({0:F1}%)'}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                            <Run Text="Ratio: "/><Run Text="{Binding SelectedChampion.AttackSpeedRatio, StringFormat='{}{0:F3}'}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Ranges -->
                                    <StackPanel>
                                        <TextBlock Text="RANGES" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,4"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="18">
                                            <Run Text="{Binding SelectedChampion.AttackRange, StringFormat='{}Atk: {0:F0}'}" FontWeight="Bold"/>
                                        </TextBlock>
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,2,0,0">
                                            <Run Text="Acq: "/><Run Text="{Binding SelectedChampion.AcquisitionRange, StringFormat='{}{0:F0}'}"/><Run Text=" | Move: "/><Run Text="{Binding SelectedChampion.BaseMoveSpeed, StringFormat='{}{0:F0}'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </UniformGrid>
                            </Border>

                            <!-- RESOURCE METRICS -->
                            <TextBlock Text="RESOURCE METRICS" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,16"/>
                            <UniformGrid Columns="2" Margin="0,0,0,32">
                                <Border Background="{StaticResource SidebarBackground}" CornerRadius="8" Padding="16" Margin="0,0,8,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedChampion.PrimaryResource.TypeName, StringFormat='{}PRIMARY ({0})'}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="20">
                                            <Run Text="{Binding SelectedChampion.PrimaryResource.BaseValue, StringFormat='{}{0:F0}'}" FontWeight="Bold"/>
                                            <Run Text="{Binding SelectedChampion.PrimaryResource.ValuePerLevel, StringFormat='{} (+{0:F0})'}" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0">
                                            <Run Text="Regen: "/><Run Text="{Binding SelectedChampion.PrimaryResource.BaseRegen, StringFormat='{}{0:F1}'}"/><Run Text="{Binding SelectedChampion.PrimaryResource.RegenPerLevel, StringFormat='{} (+{0:F2})'}" FontSize="11"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource SidebarBackground}" CornerRadius="8" Padding="16" Margin="8,0,0,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Visibility="{Binding SelectedChampion.SecondaryResource, Converter={StaticResource NullToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedChampion.SecondaryResource.TypeName, StringFormat='{}SECONDARY ({0})'}" Foreground="{StaticResource TextMuted}" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock Foreground="{StaticResource TextPrimary}" FontSize="20">
                                            <Run Text="{Binding SelectedChampion.SecondaryResource.BaseValue, StringFormat='{}{0:F0}'}" FontWeight="Bold"/>
                                            <Run Text="{Binding SelectedChampion.SecondaryResource.ValuePerLevel, StringFormat='{} (+{0:F0})'}" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- MECHANICAL ABILITIES -->
                            <TextBlock Text="MECHANICAL ABILITIES" Style="{StaticResource ToolSectionLabel}" Margin="0,0,0,16"/>
                            <!-- Passive Card -->
                            <Border Background="{StaticResource SidebarBackground}" CornerRadius="10" Padding="24" Margin="0,0,0,20" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Width="56" Height="56" Background="{StaticResource CardBackground}" CornerRadius="8" VerticalAlignment="Top" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding SelectedChampion.Passive.IconSource}" Stretch="UniformToFill"/>
                                            <TextBlock Text="P" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,2" FontWeight="Black" FontSize="14" Foreground="White" Visibility="{Binding SelectedChampion.Passive.IconSource, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock Text="{Binding SelectedChampion.Passive.Name}" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding SelectedChampion.Passive.Summary}" FontSize="13" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,10" FontWeight="SemiBold" Visibility="{Binding SelectedChampion.Passive.Summary, Converter={StaticResource NullToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding SelectedChampion.Passive.Description}" FontSize="13" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding SelectedChampion.Abilities}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource SidebarBackground}" CornerRadius="10" Padding="24" Margin="0,0,0,20" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,16">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <Border Width="56" Height="56" Background="{StaticResource CardBackground}" CornerRadius="8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding IconSource}" Stretch="UniformToFill"/>
                                                            <TextBlock Text="{Binding Key}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,2" FontWeight="Black" FontSize="14" Foreground="White"/>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimary}"/>
                                                        <TextBlock Text="{Binding Summary}" FontSize="13" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Visibility="{Binding Summary, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding CooldownDisplay, StringFormat='{}CD: {0}'}" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" Visibility="{Binding CooldownDisplay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                        <TextBlock Text="{Binding CostDisplay, StringFormat='{}COST: {0}'}" FontSize="11" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right" Visibility="{Binding CostDisplay, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock Text="{Binding Description}" FontSize="13" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" LineHeight="20" Opacity="0.9"/>
                                                
                                                <ItemsControl ItemsSource="{Binding DataValues}" Margin="0,16,0,0">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{StaticResource CardBackground}" CornerRadius="4" Padding="8,4" Margin="0,0,8,8" BorderBrush="{StaticResource BorderColor}" BorderThickness="0.5">
                                                                <TextBlock FontSize="11">
                                                                    <Run Text="{Binding Key, StringFormat='{}{0}: '}" Foreground="{StaticResource TextMuted}" FontWeight="Bold"/>
                                                                    <Run Text="{Binding Value}" Foreground="{StaticResource AccentBrush}"/>
                                                                </TextBlock>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- LORE SECTION -->
                            <TextBlock Text="BIOGRAPHICAL LOG (LORE)" Style="{StaticResource ToolSectionLabel}" Margin="0,16,0,16"/>
                            <Border Background="{StaticResource SidebarBackground}" CornerRadius="10" Padding="24" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <TextBlock Text="{Binding SelectedChampion.Lore}" FontSize="14" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontStyle="Italic" Opacity="0.8" LineHeight="22"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
