<UserControl x:Class="AssetsManager.Views.ExplorerWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:explorer="clr-namespace:AssetsManager.Views.Controls.Explorer"
             mc:Ignorable="d" 
             FontFamily="{StaticResource AppFontFamily}">
    <Grid>
        <!-- Cuerpo Principal -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="750*" MinWidth="250"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1000*" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- Panel Izquierdo: Explorador -->
            <Border Grid.Column="0" 
                    BorderBrush="{StaticResource BorderColor}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=FileExplorer, Path=DataContext.IsTreeReady}" Value="False">
                                <Setter Property="Grid.ColumnSpan" Value="3"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <explorer:FileExplorerControl x:Name="FileExplorer" FileSelected="FileExplorer_FileSelected"/>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ShowsPreview="False"
                          Visibility="{Binding ElementName=FileExplorer, Path=DataContext.IsTreeReady, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <!-- Panel Derecho: Previsualizador -->
            <Border Grid.Column="2"
                    Visibility="{Binding ElementName=FileExplorer, Path=DataContext.IsTreeReady, Converter={StaticResource BooleanToVisibilityConverter}}">
                <explorer:FilePreviewerControl x:Name="FilePreviewer"/>
            </Border>
        </Grid>

        <!-- Loading Indicator (Overlay) -->
        <Grid x:Name="LoadingIndicator" 
              Visibility="{Binding ElementName=FileExplorer, Path=DataContext.IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" 
              IsHitTestVisible="True">
            
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                
                <!-- ADVANCED PROGRESS RING COMPOSITION -->
                <Grid Width="100" Height="100" HorizontalAlignment="Center">
                    <!-- 1. Outer Static Glow Ring -->
                    <Ellipse Stroke="{StaticResource AccentBrush}" 
                             StrokeThickness="1" 
                             Opacity="0.1" 
                             Margin="-10"/>
                    
                    <!-- 2. Technical Background Ring -->
                    <Ellipse Stroke="{StaticResource BorderColor}" 
                             StrokeThickness="4" 
                             Opacity="0.3"/>
                    
                    <!-- 3. Pulsing Core Glow -->
                    <Ellipse Fill="{StaticResource AccentBrush}" 
                             Opacity="0.05"
                             Style="{StaticResource TechnicalGlowStyle}"/>

                    <!-- 4. Rotating "Scanner" Arc -->
                    <materialIcons:MaterialIcon Kind="Loading" 
                                                Width="60" 
                                                Height="60" 
                                                Foreground="{StaticResource AccentBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource SpinningIconStyle}">
                    </materialIcons:MaterialIcon>
                    
                    <!-- 5. Central Static Identity Icon -->
                    <materialIcons:MaterialIcon Kind="FolderSearch" 
                                                Width="20" 
                                                Height="20" 
                                                Foreground="{StaticResource TextSecondary}"
                                                Opacity="0.6"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                </Grid>
                
                <!-- TECHNICAL TEXT COMPOSITION -->
                <StackPanel Margin="0,30,0,0">
                    <!-- Main Status (All-Caps Tech Style) -->
                    <TextBlock Text="{Binding ElementName=FileExplorer, Path=DataContext.LoadingOperation}" 
                               FontSize="11"
                               FontWeight="Black"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center" 
                               Opacity="0.9">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="{Binding Color, Source={StaticResource AccentBrush}}" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Dynamic Detail Message -->
                    <TextBlock Text="{Binding ElementName=FileExplorer, Path=DataContext.LoadingStatus}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"
                               HorizontalAlignment="Center" 
                               Margin="0,4,0,0"/>

                    <!-- Separator Line -->
                    <Rectangle Width="40" Height="2" 
                               Fill="{StaticResource AccentBrush}" 
                               HorizontalAlignment="Center" 
                               Margin="0,12" 
                               Opacity="0.5"/>

                    <!-- Sub-Detail Detail Message -->
                    <TextBlock Text="{Binding ElementName=FileExplorer, Path=DataContext.LoadingDetail}"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               HorizontalAlignment="Center" 
                               Opacity="0.8"/>
                </StackPanel>
             </StackPanel>
        </Grid>
    </Grid>
</UserControl>
