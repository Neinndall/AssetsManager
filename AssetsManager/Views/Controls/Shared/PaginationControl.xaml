<UserControl x:Class="AssetsManager.Views.Controls.Shared.PaginationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d"
             d:DesignHeight="24" d:DesignWidth="140">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                Visibility="{Binding Paginator.TotalPages, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CountToVisibilityConverter}}">

        <Button Style="{StaticResource PaginationNavButtonStyle}"
                Click="FirstPage_Click"
                IsEnabled="{Binding Paginator.CanGoToFirstPage, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=False}"
                ToolTip="First page">
            <materialIcons:MaterialIcon Kind="PageFirst" Width="12" Height="12"/>
        </Button>

        <Button Style="{StaticResource PaginationNavButtonStyle}"
                Click="PreviousPage_Click"
                IsEnabled="{Binding Paginator.CanGoToPreviousPage, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=False}"
                ToolTip="Previous page">
            <materialIcons:MaterialIcon Kind="ChevronLeft" Width="14" Height="14"/>
        </Button>

        <TextBlock Text="{Binding Paginator.PageInfo, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='0 / 0'}"
                   Foreground="{StaticResource TextSecondary}"
                   FontSize="11"
                   Margin="6,0"
                   MinWidth="36"
                   TextAlignment="Center"
                   VerticalAlignment="Center"/>

        <Button Style="{StaticResource PaginationNavButtonStyle}"
                Click="NextPage_Click"
                IsEnabled="{Binding Paginator.CanGoToNextPage, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=False}"
                ToolTip="Next page">
            <materialIcons:MaterialIcon Kind="ChevronRight" Width="14" Height="14"/>
        </Button>

        <Button Style="{StaticResource PaginationNavButtonStyle}"
                Click="LastPage_Click"
                IsEnabled="{Binding Paginator.CanGoToLastPage, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=False}"
                ToolTip="Last page">
            <materialIcons:MaterialIcon Kind="PageLast" Width="12" Height="12"/>
        </Button>
    </StackPanel>
</UserControl>
