<UserControl x:Class="AssetsManager.Views.Controls.Monitor.ApiControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:local="clr-namespace:AssetsManager.Views.Controls.Monitor"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000">
    
    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 1. Control Row (Card + Buttons) -->
            <RowDefinition Height="Auto"/> <!-- 2. Tab Selector -->
            <RowDefinition Height="*"/>    <!-- 3. Content Area -->
        </Grid.RowDefinitions>
        
        <!-- 1. CONTROL ROW -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Config Section (Conditional) -->
                <RowDefinition Height="Auto"/> <!-- Main Header -->
            </Grid.RowDefinitions>

            <!-- 1.1 CONFIG SECTION: Visible only for Pass Rewards -->
            <Border Grid.Row="0" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20,14" Margin="0,0,0,16" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    Visibility="{Binding IsChecked, ElementName=TabPass, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border Grid.Column="0" Background="{StaticResource HoverColor}" CornerRadius="10" Width="44" Height="44" Margin="0,0,16,0">
                        <materialIcons:MaterialIcon Kind="Identifier" Foreground="{StaticResource AccentTeal}" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Content -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <Grid.ColumnDefinition Width="Auto"/>
                            <Grid.ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Texts -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Manual Pass ID" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="-2,0,0,0"/>
                            <TextBlock Text="Leave empty for auto-discovery or enter a custom Event ID." FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="-2,2,0,0"/>
                        </StackPanel>

                        <!-- Input -->
                        <TextBox Grid.Column="1" Width="300" Height="36" Style="{StaticResource ModernTextBoxEditable}" 
                                 HorizontalAlignment="Right" VerticalAlignment="Center"
                                 Text="{Binding ManualPassId, UpdateSourceTrigger=PropertyChanged}" 
                                 Tag="Enter custom Event ID..."/>
                    </Grid>
                </Grid>
            </Border>

            <!-- 1.2 MAIN HEADER: Info Card & Connect -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <Definition Width="*"/>    <!-- Info Card -->
                    <Definition Width="Auto"/> <!-- Connect Button -->
                    <Definition Width="Auto"/> <!-- Action Buttons -->
                </Grid.ColumnDefinitions>

                <!-- LEFT: LCU Info Card -->
                <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20,14" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,12,0" Height="90">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/> <!-- Icon -->
                            <ColumnDefinition Width="Auto"/> <!-- Status -->
                            <ColumnDefinition Width="*"/>    <!-- Profile Info -->
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource HoverColor}" CornerRadius="10" Width="44" Height="44" Margin="0,0,16,0">
                            <materialIcons:MaterialIcon Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialIcons:MaterialIcon.Style>
                                    <Style TargetType="materialIcons:MaterialIcon">
                                        <Setter Property="Kind" Value="LinkVariantOff" />
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Kind" Value="LinkVariant" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreen}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="Status: Connecting...">
                                                <Setter Property="Kind" Value="Sync" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialIcons:MaterialIcon.Style>
                            </materialIcons:MaterialIcon>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="LCU SERVICE" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="-2,0,0,0"/>
                            <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="-2,2,0,0"/>
                        </StackPanel>

                        <!-- Profile/Connection Metrics (Right Aligned) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <!-- Display Name -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                <materialIcons:MaterialIcon Kind="AccountCircle" Width="14" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.8"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="Black" Foreground="{StaticResource TextPrimary}" LineHeight="13"/>
                                    <TextBlock Text="USER IDENTITY" FontSize="8" FontWeight="Black" Foreground="{StaticResource TextMuted}" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Region -->
                            <StackPanel Orientation="Horizontal">
                                <materialIcons:MaterialIcon Kind="Earth" Width="14" Foreground="{StaticResource AccentBlue}" Margin="0,0,8,0" VerticalAlignment="Center" Opacity="0.8"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Region}" FontSize="13" FontWeight="Black" Foreground="{StaticResource TextPrimary}" LineHeight="13"/>
                                    <TextBlock Text="SERVER REGION" FontSize="8" FontWeight="Black" Foreground="{StaticResource TextMuted}" Opacity="0.7"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MIDDLE: Connect Button -->
                <Button Grid.Column="1" Click="ConnectLcu_Click" Style="{StaticResource SelectionCardButtonStyle}" Margin="0,0,6,0" Width="140" Height="90" Padding="0">
                    <StackPanel VerticalAlignment="Center">
                        <materialIcons:MaterialIcon Kind="Link" Width="24" Height="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Connect LCU" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Text="Link local client" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- RIGHT: Action Buttons (Uniform Grid for fixed sizing) -->
                <UniformGrid Grid.Column="2" Columns="6" Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button Click="SyncLiveCatalog_Click" Style="{StaticResource SelectionCardButtonStyle}" Margin="6,0,6,0" Height="90" Padding="0">
                        <StackPanel VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="Refresh" Width="24" Height="24" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Sync Sales" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Refresh offers" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="SyncMythicShop_Click" Style="{StaticResource SelectionCardButtonStyle}" Margin="6,0,6,0" Height="90" Padding="0">
                        <StackPanel VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="ImageOutline" Width="24" Height="24" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Mythic Shop" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="View rare items" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="SyncPassRewards_Click" Style="{StaticResource SelectionCardButtonStyle}" Margin="6,0,0,0" Height="90" Padding="0">
                        <StackPanel VerticalAlignment="Center">
                            <materialIcons:MaterialIcon Kind="AutoFix" Width="24" Height="24" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Pass Rewards" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Track progress" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </Grid>
        </Grid>

        <!-- 2. TAB SELECTOR -->
        <Border Grid.Row="1" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="4" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,0,12" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="TabSales" Content="Sales &amp; Offers" IsChecked="True" GroupName="ApiTabs" Style="{StaticResource SegmentedRadioButtonStyle}" MinWidth="160"/>
                <RadioButton x:Name="TabMythic" Content="Mythic Shop" GroupName="ApiTabs" Style="{StaticResource SegmentedRadioButtonStyle}" MinWidth="160"/>
                <RadioButton x:Name="TabPass" Content="Pass Rewards" GroupName="ApiTabs" Style="{StaticResource SegmentedRadioButtonStyle}" MinWidth="160"/>
            </StackPanel>
        </Border>

        <!-- 3. CONTENT AREA -->
        <Grid Grid.Row="2">
            <!-- 3.1 SALES & OFFERS -->
            <ListView x:Name="SalesListView" ItemsSource="{Binding ActiveSales}" Style="{StaticResource ModernListView}" Background="Transparent" BorderThickness="0"
                      Visibility="{Binding IsChecked, ElementName=TabSales, Converter={StaticResource BooleanToVisibilityConverter}}">
                <!-- DataTemplate shared with Mythic via ItemTemplate -->
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,6">
                            <Border Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"/>
                            <Border BorderThickness="2,0,0,0" BorderBrush="{StaticResource AccentBrush}" CornerRadius="10,0,0,10"/>
                            <Grid Margin="16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="{StaticResource HoverColor}" Margin="0,0,16,0">
                                    <materialIcons:MaterialIcon Kind="ShoppingOutline" Width="20" Height="20" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding PriceDisplay}" FontWeight="Black" FontSize="14" Foreground="{StaticResource AccentOrange}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="CURRENT OFFER" FontSize="8" FontWeight="Bold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 3.2 MYTHIC SHOP -->
            <ListView x:Name="MythicListView" ItemsSource="{Binding MythicItems}" Style="{StaticResource ModernListView}" Background="Transparent" BorderThickness="0"
                      Visibility="{Binding IsChecked, ElementName=TabMythic, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,6">
                            <Border Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"/>
                            <Border BorderThickness="2,0,0,0" BorderBrush="{StaticResource AccentPurple}" CornerRadius="10,0,0,10"/>
                            <Grid Margin="16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="{StaticResource HoverColor}" Margin="0,0,16,0">
                                    <materialIcons:MaterialIcon Kind="StarCircleOutline" Width="20" Height="20" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Mythic Content" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding EssencePrice}" FontWeight="Black" FontSize="14" Foreground="{StaticResource AccentPurple}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="MYTHIC ESSENCE" FontSize="8" FontWeight="Bold" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 3.3 PASS REWARDS (Grouped) -->
            <ListView x:Name="PassListView" ItemsSource="{Binding PassGroups}" Style="{StaticResource ModernListView}" Background="Transparent" BorderThickness="0"
                      Visibility="{Binding IsChecked, ElementName=TabPass, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,12">
                            <Border Background="{StaticResource CardBackground}" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"/>
                            <Grid Margin="20,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                    <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource HoverColor}">
                                        <materialIcons:MaterialIcon Kind="TrophyOutline" Width="20" Height="20" Foreground="{StaticResource AccentGreen}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="{Binding GroupName}" FontWeight="Black" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{Binding GroupInfo}" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                </StackPanel>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Rewards}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SidebarBackground}" CornerRadius="8" Margin="0,0,0,4" Padding="12,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="4" Background="{StaticResource HoverColor}" Margin="0,0,12,0">
                                                        <materialIcons:MaterialIcon Kind="GiftOutline" Width="16" Height="16" Foreground="{StaticResource AccentTeal}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding RewardName}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                                        <TextBlock Text="{Binding RewardType}" FontSize="9" Foreground="{StaticResource TextMuted}"/>
                                                    </StackPanel>
                                                    <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding MilestoneText}" FontSize="10" FontWeight="Black" Foreground="{StaticResource AccentGreen}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</UserControl>