<UserControl x:Class="AssetsManager.Views.Controls.Monitor.HistoryViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:AssetsManager.Views.Controls.Monitor"
             xmlns:shared="clr-namespace:AssetsManager.Views.Controls.Shared"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:converters="clr-namespace:AssetsManager.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="800">

    <UserControl.Resources>
        <converters:EqualityConverter x:Key="EqualityConverter"/>
    </UserControl.Resources>

    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0. Search & Info Header -->
            <RowDefinition Height="Auto"/> <!-- 1. Tabs & Pagination Header -->
            <RowDefinition Height="*"/>    <!-- 2. Content Lists -->
        </Grid.RowDefinitions>

        <!-- 0. ACTIONS & SEARCH ROW (Balanced Proportions) -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>    <!-- Search Card (Flexible) -->
                <ColumnDefinition Width="160"/>  <!-- Sync Button (Slimmer) -->
            </Grid.ColumnDefinitions>

            <!-- LEFT: Search Card -->
            <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="12" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" Margin="0,0,12,0" Height="90">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon Box -->
                    <Border Grid.Column="0" Background="{StaticResource HoverColor}" CornerRadius="10" Width="42" Height="42" VerticalAlignment="Center" Margin="0,0,16,0">
                        <materialIcons:MaterialIcon Kind="ClockOutline" Foreground="{StaticResource AccentBrush}" Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Text -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="History Explorer" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="-2,0,0,0"/>
                        <TextBlock Text="Audit and restore comparisons, watchers and WadFiles" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="-2,2,0,0"/>
                    </StackPanel>

                    <!-- Search Input -->
                    <Border Grid.Column="2" 
                            Background="{StaticResource SidebarBackground}" 
                            BorderBrush="{StaticResource BorderColor}" 
                            BorderThickness="1" 
                            CornerRadius="10" 
                            Padding="0"
                            Width="260" Height="44"
                            VerticalAlignment="Center">
                        <Grid>
                            <TextBox x:Name="txtSearch" 
                                     Style="{StaticResource ResourceKey=StandardSearchBoxStyle}" 
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="12,0"
                                     VerticalContentAlignment="Center"
                                     TextChanged="TxtSearch_TextChanged" 
                                     Tag="Search history entries..."/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT: Sync History -->
            <Button Grid.Column="1" 
                    Click="btnSyncBackups_Click" 
                    Style="{StaticResource SelectionCardButtonStyle}" 
                    Margin="0" 
                    Height="90" 
                    Padding="0" 
                    HorizontalContentAlignment="Stretch" 
                    VerticalContentAlignment="Stretch">
                <StackPanel VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="Sync" Width="24" Height="24" Foreground="{StaticResource AccentBlue}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Sync History" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="Import missing folders" FontSize="10" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 1. TABS & PAGINATION HEADER (Floating Style) -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/> <!-- Tabs -->
                <ColumnDefinition Width="*"/>    <!-- Spacer -->
                <ColumnDefinition Width="Auto"/> <!-- Pagination -->
            </Grid.ColumnDefinitions>

            <!-- SEGMENTED TABS -->
            <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="4" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Comparisons" 
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=0, Mode=TwoWay}" 
                                 GroupName="HistoryTabs" Style="{StaticResource SegmentedRadioButtonStyle}" MinWidth="110"/>
                    <RadioButton Content="Watcher" 
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=1, Mode=TwoWay}" 
                                 GroupName="HistoryTabs" Style="{StaticResource SegmentedRadioButtonStyle}" MinWidth="110"/>
                    <RadioButton Content="WadFile" 
                                 IsChecked="{Binding SelectedTabIndex, Converter={StaticResource EqualityConverter}, ConverterParameter=2, Mode=TwoWay}" 
                                 GroupName="HistoryTabs" Style="{StaticResource SegmentedRadioButtonStyle}" MinWidth="110"/>
                </StackPanel>
            </Border>

            <!-- SHARED PAGINATION -->
            <shared:PaginationControl Grid.Column="2" Paginator="{Binding Paginator}" VerticalAlignment="Center"/>
        </Grid>

        <!-- 2. CONTENT LISTS -->
        <Grid Grid.Row="2">
            <!-- COMMON LISTVIEW STYLE -->
            <Grid.Resources>
                <Style x:Key="HistoryListViewStyle" TargetType="ListView" BasedOn="{StaticResource ModernListView}">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>

                <Style x:Key="HistoryItemStyle" TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- DataTemplate shared for all history lists -->
                <DataTemplate x:Key="HistoryEntryTemplate">
                    <Grid>
                        <!-- 1. Background -->
                        <Border x:Name="CardBorder" Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- 2. Accent Strip -->
                        <Border x:Name="AccentStrip" BorderThickness="2,0,0,0" CornerRadius="10,0,0,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="WadFile">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentOrange}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Type}" Value="WatcherUpdate">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- 3. Content -->
                        <Grid Margin="16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                <ColumnDefinition Width="*"/>    <!-- Info -->
                                <ColumnDefinition Width="Auto"/> <!-- Actions -->
                            </Grid.ColumnDefinitions>

                            <!-- Professional Icon Box -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Background="{StaticResource SidebarBackground}" Margin="0,0,16,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <materialIcons:MaterialIcon Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialIcons:MaterialIcon.Style>
                                        <Style TargetType="materialIcons:MaterialIcon">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                            <Setter Property="Kind" Value="DatabaseOutline"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="WadFile">
                                                    <Setter Property="Kind" Value="FileCompare"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="WadArchive">
                                                    <Setter Property="Kind" Value="PackageVariantClosed"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="WatcherUpdate">
                                                    <Setter Property="Kind" Value="Radar"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialIcons:MaterialIcon.Style>
                                </materialIcons:MaterialIcon>
                            </Border>

                            <!-- Info Section -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontWeight="Black" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DisplayName, StringFormat='{}Comparison | {0}'}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="WatcherUpdate">
                                                    <Setter Property="Text" Value="{Binding DisplayName, StringFormat='{}Watcher | {0}'}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="WadFile">
                                                    <Setter Property="Text" Value="{Binding DisplayName, StringFormat='{}WadFile | {0}'}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DisplayName}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="{Binding FileName}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DisplayName}" Value="">
                                                    <Setter Property="Text" Value="{Binding FileName}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource HoverColor}" CornerRadius="6" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="Tag" Width="11" Height="11" Foreground="{StaticResource TextMuted}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Version}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Version}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="v1.0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Version}" Value="">
                                                                <Setter Property="Text" Value="v1.0"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource HoverColor}" CornerRadius="6" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="CalendarClock" Width="11" Height="11" Foreground="{StaticResource TextMuted}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:dd MMM yyyy · HH:mm}'}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource HoverColor}" CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="FolderOutline" Width="11" Height="11" Foreground="{StaticResource TextMuted}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReferenceId}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Actions Section -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Click="btnEditName_Click" Width="30" Height="30" Margin="0,0,6,0">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TransparentIconButton}">
                                            <Setter Property="ToolTip" Value="Rename Comparison"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="WatcherUpdate">
                                                    <Setter Property="ToolTip" Value="Rename Watcher"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="WadFile">
                                                    <Setter Property="ToolTip" Value="Rename WadFile"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <materialIcons:MaterialIcon Kind="Rename" Width="18" Height="18" Foreground="{StaticResource TextSecondary}"/>
                                </Button>

                                <Button Click="btnViewDiff_Click" Width="34" Height="34" Margin="0,0,6,0" Background="{StaticResource SidebarBackground}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource TransparentIconButton}">
                                            <Setter Property="ToolTip" Value="View Historical Data"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="WatcherUpdate">
                                                    <Setter Property="ToolTip" Value="View Differences"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <materialIcons:MaterialIcon Kind="FileCompare" Width="18" Height="18" Foreground="{StaticResource AccentBrush}"/>
                                </Button>

                                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0,10,0" Background="{StaticResource BorderColor}"/>

                                <Button Click="btnRemoveSelected_Click" Style="{StaticResource TransparentIconButton}" Width="30" Height="30" ToolTip="Remove from History">
                                    <materialIcons:MaterialIcon Kind="TrashCanOutline" Width="18" Height="18" Foreground="{StaticResource AccentRed}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </Grid.Resources>

            <!-- 1. COMPARISONS LIST -->
            <ListView x:Name="ComparisonsListView" 
                      ItemContainerStyle="{StaticResource HistoryItemStyle}"
                      ItemTemplate="{StaticResource HistoryEntryTemplate}"
                      ItemsSource="{Binding ComparisonsPaginator.PagedItems}">
                <ListView.Style>
                    <Style TargetType="ListView" BasedOn="{StaticResource HistoryListViewStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
            </ListView>

            <!-- 2. WATCHER LIST -->
            <ListView x:Name="WatcherListView" 
                      ItemContainerStyle="{StaticResource HistoryItemStyle}"
                      ItemTemplate="{StaticResource HistoryEntryTemplate}"
                      ItemsSource="{Binding WatcherPaginator.PagedItems}">
                <ListView.Style>
                    <Style TargetType="ListView" BasedOn="{StaticResource HistoryListViewStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
            </ListView>

            <!-- 3. DIFFERENCES LIST -->
            <ListView x:Name="DifferencesListView" 
                      ItemContainerStyle="{StaticResource HistoryItemStyle}"
                      ItemTemplate="{StaticResource HistoryEntryTemplate}"
                      ItemsSource="{Binding DifferencesPaginator.PagedItems}">
                <ListView.Style>
                    <Style TargetType="ListView" BasedOn="{StaticResource HistoryListViewStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListView.Style>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
