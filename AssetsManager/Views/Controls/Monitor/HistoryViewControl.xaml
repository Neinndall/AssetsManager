<UserControl x:Class="AssetsManager.Views.Controls.Monitor.HistoryViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AssetsManager.Views.Controls.Monitor"
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">

    <Grid Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 1. Pagination -->
            <RowDefinition Height="*"/>    <!-- 2. List -->
        </Grid.RowDefinitions>
        
        <!-- 1. PAGINATION TOOLBAR -->
        <Border Grid.Row="0" Margin="0,0,0,16" Background="{StaticResource SidebarBackground}" CornerRadius="8" Padding="12,8" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon Kind="FilterList" Width="16" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0"/>
                    <TextBlock Text="Historical Log Entries" FontSize="11" FontWeight="Black" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Pagination Controls -->
                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Visibility="{Binding Paginator.TotalPages, Converter={StaticResource CountToVisibilityConverter}}">
                    <Button Style="{StaticResource TransparentIconButton}" Click="PrevPage_Click" IsEnabled="{Binding Paginator.CanGoToPreviousPage}" Width="28" Height="28">
                        <materialIcons:MaterialIcon Kind="ChevronLeft" Width="20" Foreground="{StaticResource TextSecondary}"/>
                    </Button>

                    <Border Background="{StaticResource CardBackground}" CornerRadius="4" Padding="12,4" Margin="8,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                        <TextBlock Text="{Binding Paginator.PageInfo}" Foreground="{StaticResource TextPrimary}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>

                    <Button Style="{StaticResource TransparentIconButton}" Click="NextPage_Click" IsEnabled="{Binding Paginator.CanGoToNextPage}" Width="28" Height="28">
                        <materialIcons:MaterialIcon Kind="ChevronRight" Width="20" Foreground="{StaticResource TextSecondary}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. HISTORY LIST -->
        <ListView x:Name="DiffHistoryListView" 
                  Grid.Row="1"
                  ItemsSource="{Binding Paginator.PagedItems}" 
                  Style="{StaticResource ModernListView}"
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Margin" Value="0,0,0,6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <!-- 1. Background -->
                        <Border x:Name="CardBorder" Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- 2. Accent Strip -->
                        <Border x:Name="AccentStrip" BorderThickness="4,0,0,0" BorderBrush="{StaticResource AccentBrush}" CornerRadius="10,0,0,10"/>

                        <!-- 3. Content -->
                        <Grid Margin="16,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/> <!-- Icon -->
                                <ColumnDefinition Width="*"/>    <!-- Info -->
                                <ColumnDefinition Width="Auto"/> <!-- Actions -->
                            </Grid.ColumnDefinitions>

                            <!-- Professional Icon Box -->
                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Background="{StaticResource SidebarBackground}" Margin="0,0,16,0" BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                                <materialIcons:MaterialIcon Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <materialIcons:MaterialIcon.Style>
                                        <Style TargetType="materialIcons:MaterialIcon">
                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                            <Setter Property="Kind" Value="DatabaseOutline"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Type}" Value="FileDiff">
                                                    <Setter Property="Kind" Value="FileCompare"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentOrange}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Type}" Value="WadComparison">
                                                    <Setter Property="Kind" Value="PackageVariantClosed"/>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialIcons:MaterialIcon.Style>
                                </materialIcons:MaterialIcon>
                            </Border>

                            <!-- Info Section -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <!-- Main Title: COMPARISON - [ClientName] -->
                                <TextBlock FontWeight="Black" FontSize="13" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,6" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DisplayName, StringFormat='{}Comparison | {0}'}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DisplayName}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="{Binding FileName}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding DisplayName}" Value="">
                                                    <Setter Property="Text" Value="{Binding FileName}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                
                                <StackPanel Orientation="Horizontal">
                                    <!-- Version Badge (Standardized with Timestamp style) -->
                                    <Border Background="{StaticResource HoverColor}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                            Visibility="{Binding Version, Converter={StaticResource NullToVisibilityConverter}}"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="Tag" Width="11" Height="11" Foreground="{StaticResource TextMuted}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Version, StringFormat='{}v{0}'}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Timestamp Badge -->
                                    <Border Background="{StaticResource HoverColor}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="CalendarClock" Width="11" Height="11" Foreground="{StaticResource TextMuted}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:dd MMM yyyy · HH:mm}'}" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Storage ID Badge -->
                                    <Border Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialIcons:MaterialIcon Kind="FolderOutline" Width="11" Height="11" Foreground="{StaticResource TextMuted}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ReferenceId}" FontSize="10" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Actions Section -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Click="btnEditName_Click" ToolTip="Rename Comparison"
                                        Style="{StaticResource TransparentIconButton}"
                                        Width="30" Height="30" Margin="0,0,6,0">
                                    <materialIcons:MaterialIcon Kind="Rename" Width="16" Height="16" Foreground="{StaticResource TextSecondary}"/>
                                </Button>

                                <Button Click="btnViewDiff_Click" ToolTip="Explore Historical Data" 
                                        Style="{StaticResource TransparentIconButton}" 
                                        Width="34" Height="34" Margin="0,0,6,0" Background="{StaticResource SidebarBackground}">
                                    <materialIcons:MaterialIcon Kind="ChevronRight" Width="22" Height="22" Foreground="{StaticResource AccentBrush}"/>
                                </Button>
                                
                                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0,10,0" Background="{StaticResource BorderColor}"/>

                                <Button Click="btnRemoveSelected_Click" Style="{StaticResource TransparentIconButton}" Width="30" Height="30" ToolTip="Purge from History">
                                    <materialIcons:MaterialIcon Kind="DeleteSweepOutline" Width="18" Foreground="{StaticResource AccentRed}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>