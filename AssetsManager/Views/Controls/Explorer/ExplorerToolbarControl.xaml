<UserControl x:Class="AssetsManager.Views.Controls.Explorer.ExplorerToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d">
    
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
            
            <!-- HEADER BAR (Hamburger + Searcher) -->
            <Border Background="{StaticResource CardBackground}" 
                    Padding="4" 
                    BorderBrush="{StaticResource BorderColor}" 
                    HorizontalAlignment="Stretch"
                    Panel.ZIndex="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsToolsExpanded}" Value="True">
                                <Setter Property="CornerRadius" Value="10,10,0,0"/>
                                <Setter Property="BorderThickness" Value="1,1,1,0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Toggle Tools Button (Hamburger) -->
                    <ToggleButton x:Name="ToolsToggleButton" 
                                  Style="{StaticResource TransparentIconToggleButton}" 
                                  IsChecked="{Binding IsToolsExpanded}"
                                  Margin="0,0,2,0">
                        <materialIcons:MaterialIcon Kind="{Binding IsToolsExpanded, Converter={StaticResource BooleanToMaterialIconConverter}, ConverterParameter='MenuOpen,Menu'}" Width="18" Height="18"/>
                    </ToggleButton>

                    <!-- Searcher Toggle -->
                    <ToggleButton x:Name="SearchToggleButton" 
                                  Style="{StaticResource SearchToggleStyle}" 
                                  IsChecked="{Binding IsSearchVisible}"
                                  Click="SearchToggleButton_Click"
                                  Margin="2,0,4,0"/>

                    <!-- Search Box (Visibility handled by Width animation in Style) -->
                    <Grid x:Name="SearchGroup">
                        <TextBox x:Name="SearchTextBox" 
                                 Style="{StaticResource AnimatedSearchBoxStyle}" 
                                 Tag="{Binding IsSearchVisible}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,4,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- EXPANDED TOOLS PANEL -->
            <Border Background="{StaticResource SidebarBackground}" 
                    Padding="4,2" 
                    Margin="0,0,0,0"
                    BorderBrush="{StaticResource BorderColor}" 
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,10,10"
                    HorizontalAlignment="Stretch"
                    Visibility="{Binding IsToolsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    
                    <!-- 1. Collapse -->
                    <Button x:Name="CollapseToContainerButton" 
                            Style="{StaticResource HUDToolItemStyle}" 
                            Tag="Collapse"
                            Content="ArrowCollapseAll"
                            Margin="0,0,1,0"
                            Click="CollapseToContainerButton_Click"/>

                    <!-- 2. Load Backup -->
                    <Button x:Name="LoadComparisonButton" 
                            Style="{StaticResource HUDToolItemStyle}" 
                            Tag="Backup"
                            Content="FileUpload"
                            Margin="0,0,1,0"
                            Click="LoadComparisonButton_Click"/>

                    <!-- 3. Switch Tree (Mode: WAD/Directory) -->
                    <Button x:Name="SwitchModeButton" 
                            Style="{StaticResource HUDToolItemStyle}"
                            Tag="{Binding SwitchModeText}"
                            Content="{Binding SwitchModeIcon}"
                            Margin="0,0,1,0"
                            Click="SwitchModeButton_Click"/>

                    <!-- 3.5 Group by Categories (Backup Mode ONLY) -->
                    <ToggleButton x:Name="GroupingToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="{Binding GroupingText}"
                                  Content="{Binding GroupingIcon}"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsGroupingEnabled}"
                                  Visibility="{Binding IsBackupMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    
                    <!-- 4. Grid View -->
                    <ToggleButton x:Name="GridViewToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="Grid"
                                  Content="ViewGridOutline"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsGridMode}"/>

                    <!-- 5. Breadcrumb -->
                    <ToggleButton x:Name="BreadcrumbToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="Breadcrumb"
                                  Content="CodeTags"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsBreadcrumbVisible}"/>

                    <!-- 6. Favorites -->
                    <ToggleButton x:Name="FavoritesToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="Favs"
                                  Content="{Binding IsFavoritesEnabled, Converter={StaticResource BooleanToMaterialIconConverter}, ConverterParameter='Star,StarOutline'}"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsFavoritesEnabled}"
                                  Visibility="{Binding DataContext.IsFavoritesToggleVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- 7. Image Merger -->
                    <Button x:Name="ImageMergerButton" 
                            Style="{StaticResource HUDToolItemStyle}" 
                            Tag="Merger"
                            Content="ViewGridPlus"
                            Margin="0,0,0,0"
                            Click="ImageMergerButton_Click"/>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
