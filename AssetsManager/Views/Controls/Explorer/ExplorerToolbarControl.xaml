<UserControl x:Class="AssetsManager.Views.Controls.Explorer.ExplorerToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d">
    
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
            
            <!-- HEADER BAR (Hamburger + Searcher) -->
            <Border Background="{StaticResource CardBackground}" 
                    Padding="4" 
                    BorderBrush="{StaticResource BorderColor}" 
                    HorizontalAlignment="Stretch"
                    Panel.ZIndex="10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsToolsExpanded}" Value="True">
                                <Setter Property="CornerRadius" Value="10,10,0,0"/>
                                <Setter Property="BorderThickness" Value="1,1,1,0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Professional Mode Indicator (Refined) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,12,0"
                                ToolTip="Environment Identity"
                                Visibility="{Binding CurrentClientName, Converter={StaticResource NullToVisibilityConverter}}">
                        <materialIcons:MaterialIcon Kind="{Binding CurrentClientIcon}" Foreground="{Binding CurrentClientBrush}" Width="16" Height="16" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding CurrentClientName}" 
                                   FontSize="11" FontWeight="Black" Foreground="{StaticResource TextPrimary}" 
                                   VerticalAlignment="Center" Margin="0,1,0,0"/>
                    </StackPanel>

                    <!-- Separator -->
                    <Rectangle Width="1" Height="16" Fill="{StaticResource BorderColor}" Margin="0,0,8,0" 
                               Visibility="{Binding CurrentClientName, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <!-- Toggle Tools Button (Hamburger) -->
                    <ToggleButton x:Name="ToolsToggleButton" 
                                  Style="{StaticResource TransparentIconToggleButton}" 
                                  IsChecked="{Binding IsToolsExpanded}"
                                  Margin="0,0,2,0">
                        <materialIcons:MaterialIcon Kind="{Binding IsToolsExpanded, Converter={StaticResource BooleanToMaterialIconConverter}, ConverterParameter='MenuOpen,Menu'}" Width="18" Height="18"/>
                    </ToggleButton>

                    <!-- Searcher Toggle -->
                    <ToggleButton x:Name="SearchToggleButton" 
                                  Style="{StaticResource SearchToggleStyle}" 
                                  IsChecked="{Binding IsSearchVisible}"
                                  Click="SearchToggleButton_Click"
                                  Margin="2,0,4,0"/>

                    <Grid x:Name="SearchGroup">
                        <TextBox x:Name="SearchTextBox" 
                                 Style="{StaticResource AnimatedSearchBoxStyle}" 
                                 Tag="{Binding IsSearchVisible}"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,4,0"
                                 GotFocus="SearchTextBox_GotFocus"
                                 LostFocus="SearchTextBox_LostFocus"
                                 PreviewKeyDown="SearchTextBox_PreviewKeyDown"
                                 PreviewMouseLeftButtonDown="SearchTextBox_PreviewMouseLeftButtonDown"/>
                        <Popup x:Name="SearchHistoryPopup"
                               PlacementTarget="{Binding ElementName=SearchTextBox}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               MinWidth="220">
                            <Border Background="{StaticResource CardBackground}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="4"
                                    Margin="0,4,0,0"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="Black" Opacity="0.3"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Header -->
                                    <Grid Grid.Row="0" Margin="6,4,6,6">
                                        <TextBlock Text="RECENT SEARCHES"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="ClearHistoryButton"
                                                Content="Clear"
                                                FontSize="9"
                                                HorizontalAlignment="Right"
                                                Cursor="Hand"
                                                Click="ClearHistoryButton_Click"
                                                Focusable="False">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="Transparent" Padding="4,2">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    
                                    <!-- List -->
                                    <ListBox Grid.Row="1"
                                             x:Name="SearchHistoryListBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             MaxHeight="200"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             SelectionChanged="SearchHistoryListBox_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="6,4">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SidebarBackground}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SidebarBackground}"/>
                                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="24">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <materialIcons:MaterialIcon Kind="History" 
                                                                                Width="12" Height="12" 
                                                                                Foreground="{StaticResource TextSecondary}" 
                                                                                VerticalAlignment="Center" 
                                                                                Margin="2,0,6,0"/>
                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding}" 
                                                               Foreground="{StaticResource TextPrimary}" 
                                                               FontSize="11" 
                                                               VerticalAlignment="Center" 
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <!-- Delete item button -->
                                                    <Button Grid.Column="2"
                                                            Click="DeleteHistoryItem_Click"
                                                            Tag="{Binding}"
                                                            Visibility="Collapsed"
                                                            x:Name="DelBtn"
                                                            Focusable="False"
                                                            Cursor="Hand">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="Button">
                                                                            <Border Background="Transparent" Padding="4">
                                                                                <materialIcons:MaterialIcon x:Name="DelIcon" Kind="Close" Width="10" Height="10" Foreground="{StaticResource TextSecondary}"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="DelIcon" Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <!-- Show delete button on hover -->
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DelBtn" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- EXPANDED TOOLS PANEL -->
            <Border Background="{StaticResource SidebarBackground}" 
                    Padding="4,2" 
                    Margin="0,0,0,0"
                    BorderBrush="{StaticResource BorderColor}" 
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,10,10"
                    HorizontalAlignment="Stretch"
                    Visibility="{Binding IsToolsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    
                    <!-- 1. Collapse -->
                    <Button x:Name="CollapseToContainerButton" 
                            Style="{StaticResource HUDToolItemStyle}" 
                            Tag="Collapse"
                            Content="ArrowCollapseAll"
                            Margin="0,0,1,0"
                            Click="CollapseToContainerButton_Click"/>

                    <!-- 2. Load Results -->
                    <Button x:Name="LoadResultsButton" 
                            Style="{StaticResource HUDToolItemStyle}" 
                            Tag="Results"
                            Content="History"
                            Margin="0,0,1,0"
                            Click="LoadResultsButton_Click"/>

                    <!-- 3. Switch Tree (Mode: WAD/Directory) -->
                    <Button x:Name="SwitchModeButton" 
                            Style="{StaticResource HUDToolItemStyle}"
                            Tag="{Binding SwitchModeText}"
                            Content="{Binding SwitchModeIcon}"
                            Margin="0,0,1,0"
                            Click="SwitchModeButton_Click"/>

                    <!-- 3.5 Group by Categories (Backup Mode ONLY) -->
                    <ToggleButton x:Name="GroupingToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="{Binding GroupingText}"
                                  Content="{Binding GroupingIcon}"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsGroupingEnabled}"
                                  Visibility="{Binding IsBackupMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    
                    <!-- 4. Grid View -->
                    <ToggleButton x:Name="GridViewToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="Grid"
                                  Content="ViewGridOutline"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsGridMode}"/>

                    <!-- 5. Breadcrumb -->
                    <ToggleButton x:Name="BreadcrumbToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="Breadcrumb"
                                  Content="CodeTags"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsBreadcrumbVisible}"/>

                    <!-- 6. Favorites -->
                    <ToggleButton x:Name="FavoritesToggleButton" 
                                  Style="{StaticResource HUDToolItemToggleStyle}"
                                  Tag="Favs"
                                  Content="{Binding IsFavoritesEnabled, Converter={StaticResource BooleanToMaterialIconConverter}, ConverterParameter='Star,StarOutline'}"
                                  Margin="0,0,1,0"
                                  IsChecked="{Binding IsFavoritesEnabled}"
                                  Visibility="{Binding DataContext.IsFavoritesToggleVisible, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- 7. Image Merger -->
                    <Button x:Name="ImageMergerButton" 
                            Style="{StaticResource HUDToolItemStyle}" 
                            Tag="Merger"
                            Content="ViewGridPlus"
                            Margin="0,0,0,0"
                            Click="ImageMergerButton_Click"/>

                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
