<UserControl x:Class="AssetsManager.Views.Controls.StatusBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="32" d:DesignWidth="1000">

    <Border x:Name="MainStatusBarBorder"
            Background="{StaticResource SidebarBackground}" 
            BorderBrush="{StaticResource BorderColor}" 
            BorderThickness="0,1,0,0"
            Height="32"
            Padding="16,0"
            VerticalAlignment="Bottom">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding StatusText}" Value="">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        
        <Grid>
            <!-- NEON STATUS LINE (Dynamic Color via BorderBrush) -->
            <ContentControl x:Name="StatusLine" VerticalAlignment="Top" Margin="-16,-1,-16,0" HorizontalAlignment="Stretch">
                <ContentControl.Style>
                    <Style TargetType="ContentControl" BasedOn="{StaticResource TechnicalScanStyle}">
                        <Style.Triggers>
                            <!-- 1. VISIBILITY: Show during progress or cancellation -->
                            <DataTrigger Binding="{Binding ProgressPercentage, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            
                            <!-- 2. COLOR & VISIBILITY: Cancellation states -->
                            <DataTrigger Binding="{Binding StatusText}" Value="Cancelling Task...">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="BorderBrush" Value="Orange"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>

            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Status Icon -->
                    <ColumnDefinition Width="*"/>    <!-- Status Text -->
                    <ColumnDefinition Width="Auto"/> <!-- Progress -->
                </Grid.ColumnDefinitions>

                <materialIcons:MaterialIcon Grid.Column="0" Width="14" Height="14" Margin="0,0,10,0" VerticalAlignment="Center">
                    <materialIcons:MaterialIcon.Style>
                        <Style TargetType="materialIcons:MaterialIcon">
                            <Setter Property="Kind" Value="InformationOutline"/>
                            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusText}" Value="Ready">
                                    <Setter Property="Kind" Value="CheckCircleOutline"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ProgressPercentage, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                    <Setter Property="Kind" Value="ProgressClock"/>
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusText}" Value="Cancelling Task...">
                                    <Setter Property="Kind" Value="AlertCircleOutline"/>
                                    <Setter Property="Foreground" Value="Orange"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialIcons:MaterialIcon.Style>
                </materialIcons:MaterialIcon>

                <TextBlock Grid.Column="1" 
                           Text="{Binding StatusText}" 
                           FontSize="11" 
                           Foreground="{StaticResource TextSecondary}" 
                           VerticalAlignment="Center" 
                           TextTrimming="CharacterEllipsis"
                           FontWeight="Medium"/>

                <Button Grid.Column="2"
                        x:Name="ProgressSummaryButton"
                        Style="{StaticResource TransparentIconButton}"
                        Visibility="{Binding ProgressPercentage, Converter={StaticResource NullToVisibilityConverter}}"
                        Padding="8,0,0,0"
                        VerticalAlignment="Center"
                        Click="ProgressSummaryButton_Click">
                    <Button.ToolTip>
                        <ToolTip Background="{StaticResource CardBackground}" BorderBrush="{StaticResource BorderColor}">
                            <TextBlock Text="View detailed progress" Foreground="{StaticResource TextPrimary}" FontSize="11"/>
                        </ToolTip>
                    </Button.ToolTip>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProgressPercentage}" 
                                   FontSize="11" 
                                   Foreground="{StaticResource AccentBrush}" 
                                   Margin="0,0,8,0" 
                                   VerticalAlignment="Center" 
                                   FontWeight="SemiBold"/>
                        
                        <materialIcons:MaterialIcon Kind="Sync" Width="16" Height="16" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center">
                            <materialIcons:MaterialIcon.Style>
                                <Style TargetType="materialIcons:MaterialIcon">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Visibility, ElementName=ProgressSummaryButton}" Value="Visible">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="SpinAnimation" Storyboard="{StaticResource SpinningIconAnimation}"/>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="SpinAnimation"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </materialIcons:MaterialIcon.Style>
                            <materialIcons:MaterialIcon.RenderTransform>
                                <RotateTransform CenterX="8" CenterY="8"/>
                            </materialIcons:MaterialIcon.RenderTransform>
                        </materialIcons:MaterialIcon>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
