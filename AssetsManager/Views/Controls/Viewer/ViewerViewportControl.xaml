<UserControl x:Class="AssetsManager.Views.Controls.Viewer.ViewerViewportControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:helix="http://helix-toolkit.org/wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <!-- CONTAINER CARD (Technical Canvas Style) -->
    <Border Background="{StaticResource SidebarBackground}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="0"
            Margin="4,4,0,4">
        
        <!-- Clipping Border (Thickness 0 to avoid double borders) -->
        <Border CornerRadius="0" ClipToBounds="True" BorderThickness="0">
            <Grid>
                <!-- 3D VIEWPORT -->
                <helix:HelixViewport3D x:Name="Viewport3D" 
                                       Background="Transparent"
                                       ShowFrameRate="{Binding IsFpsVisible}"
                                       ShowCameraInfo="False"
                                       ShowViewCube="False"
                                       IsRotationEnabled="False"
                                       IsZoomEnabled="False"
                                       PanGesture="RightClick"
                                       SnapsToDevicePixels="False"
                                       UseLayoutRounding="False"
                                       ClipToBounds="True"
                                       RenderOptions.EdgeMode="Unspecified"
                                       RenderOptions.BitmapScalingMode="HighQuality">
                    <ModelVisual3D>
                        <ModelVisual3D.Content>
                            <Model3DGroup>
                                <!-- Default 'Flat' Lighting (As it was before) -->
                                <AmbientLight x:Name="GlobalAmbientLight" Color="White"/>
                                
                                <!-- Studio Lights (Off by default) -->
                                <DirectionalLight x:Name="StudioLight" Color="Black" Direction="-1,-1,-1"/>
                                <DirectionalLight x:Name="FillLight" Color="Black" Direction="1,1,1"/>
                            </Model3DGroup>
                        </ModelVisual3D.Content>
                    </ModelVisual3D>
                </helix:HelixViewport3D>

                <!-- CAMERA GIMBAL HUD (Floating Orientation Controls) -->
                <Border HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="0,24,24,0"
                        Background="#CC18181B" 
                        CornerRadius="20"
                        Padding="4"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Visibility="{Binding IsToolbarVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
                    </Border.Effect>

                    <StackPanel Orientation="Vertical">
                        <!-- Perspective View -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Perspective View"
                                Click="SetCameraView_Click" Tag="Perspective"
                                Width="32" Height="32" Margin="0,0,0,4">
                            <materialIcons:MaterialIcon Kind="CubeOutline" Width="16" Height="16" Foreground="{StaticResource AccentBrush}"/>
                        </Button>

                        <Rectangle Height="1" Fill="#33FFFFFF" Margin="6,2" HorizontalAlignment="Stretch"/>

                        <!-- Frontal (Y+) -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Front View"
                                Click="SetCameraView_Click" Tag="Front"
                                Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="AxisYArrow" Width="16" Height="16" Foreground="#FF4CAF50"/> <!-- Green -->
                        </Button>

                        <!-- Trasera (Y-) -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Back View"
                                Click="SetCameraView_Click" Tag="Back"
                                Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="AxisYArrow" Width="16" Height="16" Foreground="#FF4CAF50" Opacity="0.4" RenderTransformOrigin="0.5,0.5">
                                <materialIcons:MaterialIcon.RenderTransform>
                                    <ScaleTransform ScaleY="-1"/>
                                </materialIcons:MaterialIcon.RenderTransform>
                            </materialIcons:MaterialIcon>
                        </Button>

                        <!-- Derecha (X+) -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Right View"
                                Click="SetCameraView_Click" Tag="Right"
                                Width="32" Height="32">
                             <materialIcons:MaterialIcon Kind="AxisXArrow" Width="16" Height="16" Foreground="#FFF44336" Opacity="0.4" RenderTransformOrigin="0.5,0.5">
                                <materialIcons:MaterialIcon.RenderTransform>
                                    <ScaleTransform ScaleX="-1"/>
                                </materialIcons:MaterialIcon.RenderTransform>
                            </materialIcons:MaterialIcon>
                        </Button>

                        <!-- Izquierda (X-) -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Left View"
                                Click="SetCameraView_Click" Tag="Left"
                                Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="AxisXArrow" Width="16" Height="16" Foreground="#FFF44336" Opacity="0.4"/>
                        </Button>

                        <!-- Superior (Z+) -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Top View"
                                Click="SetCameraView_Click" Tag="Top"
                                Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="AxisZArrow" Width="16" Height="16" Foreground="#FF2196F3"/> <!-- Blue -->
                        </Button>

                        <!-- Inferior (Z-) -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Bottom View"
                                Click="SetCameraView_Click" Tag="Bottom"
                                Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="AxisZArrow" Width="16" Height="16" Foreground="#FF2196F3" Opacity="0.4" RenderTransformOrigin="0.5,0.5">
                                <materialIcons:MaterialIcon.RenderTransform>
                                    <ScaleTransform ScaleY="-1"/>
                                </materialIcons:MaterialIcon.RenderTransform>
                            </materialIcons:MaterialIcon>
                        </Button>

                        <Rectangle Height="1" Fill="#33FFFFFF" Margin="6,2" HorizontalAlignment="Stretch"/>

                        <!-- Reset -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Reset All"
                                Click="ResetCameraButton_Click"
                                Width="32" Height="32" Margin="0,4,0,0">
                            <materialIcons:MaterialIcon Kind="ArrowCollapseAll" Width="16" Height="16" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- FLOATING TOOLBAR -->
                <Border HorizontalAlignment="Center" 
                        VerticalAlignment="Bottom" 
                        Margin="0,0,0,24"
                        Background="#CC18181B" 
                        CornerRadius="24"
                        Padding="16,8"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        Visibility="{Binding IsToolbarVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
                    </Border.Effect>
                    
                    <StackPanel Orientation="Horizontal">
                        <!-- FPS Toggle -->
                        <ToggleButton Style="{StaticResource TransparentIconToggleButton}"
                                      x:Name="FpsToggleButton"
                                      ToolTip="Show/Hide FPS"
                                      IsChecked="{Binding IsFpsVisible}"
                                      Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="Speedometer" Width="16" Height="16"/>
                        </ToggleButton>
                        
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="6,4" VerticalAlignment="Stretch"/>

                        <!-- Camera Controls -->
                        <ToggleButton Style="{StaticResource TransparentIconToggleButton}"
                                      x:Name="AutoRotateToggleButton"
                                      ToolTip="Auto-Rotate"
                                      IsChecked="{Binding IsAutoRotateActive}"
                                      Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="Autorenew" Width="16" Height="16"/>
                        </ToggleButton>
                        
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="6,4" VerticalAlignment="Stretch"/>

                        <!-- Visuals -->
                        <Button Style="{StaticResource TransparentIconButton}"
                                ToolTip="Take Screenshot"
                                Click="ScreenshotButton_Click"
                                Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="Camera" Width="16" Height="16"/>
                        </Button>
                        
                        <Rectangle Width="1" Fill="#33FFFFFF" Margin="6,4" VerticalAlignment="Stretch"/>

                        <!-- Layout -->
                        <ToggleButton Style="{StaticResource TransparentIconToggleButton}"
                                      x:Name="MaximizeToggleButton"
                                      ToolTip="Maximize/Restore Viewport"
                                      IsChecked="{Binding IsMaximized}"
                                      Width="32" Height="32">
                            <materialIcons:MaterialIcon Kind="AspectRatio" Width="16" Height="16"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>

                <!-- TOOLBAR TOGGLE FAB -->
                <ToggleButton x:Name="ToolbarToggle"
                              IsChecked="{Binding IsToolbarVisible}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Margin="0,0,24,24"
                              ToolTip="Show/Hide Toolbar"
                              Cursor="Hand">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="border"
                                    Width="48" Height="48"
                                    CornerRadius="24"
                                    Background="#CC18181B"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                                </Border.Effect>
                                <materialIcons:MaterialIcon Kind="Tune" Width="20" Height="20" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                     <Setter TargetName="border" Property="Background" Value="#E618181B"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
            </Grid>
        </Border>
    </Border>
</UserControl>
