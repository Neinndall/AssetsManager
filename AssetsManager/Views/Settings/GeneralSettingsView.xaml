<UserControl x:Class="AssetsManager.Views.Settings.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialIcons="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="1200" d:DesignWidth="800">

    <UserControl.Resources>
        <x:Array x:Key="UpdateFrequencies" Type="{x:Type System:Int32}">
            <System:Int32>1</System:Int32>
            <System:Int32>10</System:Int32>
            <System:Int32>30</System:Int32>
            <System:Int32>60</System:Int32>
        </x:Array>
    </UserControl.Resources>

    <StackPanel Margin="0,16,0,40">
        <!-- SECTION: DATA SYNCHRONIZATION -->
        <StackPanel Margin="0,0,0,40">
            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="DatabaseOutline" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="DATA SYNCHRONIZATION" FontSize="12" FontWeight="Black" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,1,0,0"/>
                </StackPanel>
            </Border>
            
            <StackPanel Margin="28,0,0,0">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Sync hashes with CDTB" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                        <TextBlock Text="Automatically acquire the latest hashes from CommunityDragon" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding Settings.SyncHashesWithCDTB, Mode=TwoWay}" Style="{StaticResource ModernToggleSwitch}"/>
                </Grid>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Asset Watcher history archive" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                        <TextBlock Text="Store historical changes detected by Asset Watcher service" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding Settings.SaveJsonHistory, Mode=TwoWay}" Style="{StaticResource ModernToggleSwitch}"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Archive comparison results" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                        <TextBlock Text="Maintain a technical record of all processed WAD differences" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding Settings.SaveWadComparisonHistory, Mode=TwoWay}" Style="{StaticResource ModernToggleSwitch}"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- SECTION: AUTOMATED MONITORING -->
        <StackPanel Margin="0,0,0,40">
            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="Sync" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="AUTOMATED MONITORING" FontSize="12" FontWeight="Black" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,1,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="28,0,0,0">
                <StackPanel Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Background application updates" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                            <TextBlock Text="Automatically check for new application versions in the background" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="swBackgroundUpdates" Grid.Column="1" IsChecked="{Binding Settings.BackgroundUpdates, Mode=TwoWay}" Style="{StaticResource ModernToggleSwitch}"/>
                    </Grid>
                    
                    <Border Margin="0,12,0,0" Background="{StaticResource CardBackground}" CornerRadius="4" Padding="16,10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                            Visibility="{Binding IsChecked, ElementName=swBackgroundUpdates, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="POLLING INTERVAL (MINUTES)" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Black"/>
                            <ComboBox Grid.Column="1" SelectedItem="{Binding Settings.UpdateCheckFrequency, Mode=TwoWay}" Width="80" Height="26" Style="{StaticResource ModernComboBox}" ItemsSource="{StaticResource UpdateFrequencies}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Asset Watcher monitoring" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                        <TextBlock Text="Real-time monitoring of local game assets and change detection after patches" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding Settings.AssetWatcherUpdates, Mode=TwoWay}" Style="{StaticResource ModernToggleSwitch}"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- SECTION: POST-COMPARISON ACTIONS -->
        <StackPanel Margin="0,0,0,40">
            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="FlashOutline" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="POST-COMPARISON ACTIONS" FontSize="12" FontWeight="Black" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,1,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="28,0,0,0">
                <!-- Extraction -->
                <StackPanel Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Auto-extract new assets" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                            <TextBlock Text="Extract discovered assets after the comparison process" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="swAutoExtract" Grid.Column="1" 
                                  IsChecked="{Binding Settings.EnableExtraction, Mode=TwoWay}" 
                                  IsEnabled="{Binding IsChecked, ElementName=swGenerateReport, Converter={StaticResource InverseBooleanConverter}}"
                                  Style="{StaticResource ModernToggleSwitch}"/>
                    </Grid>
                    
                    <Border Margin="0,12,0,0" Background="{StaticResource CardBackground}" CornerRadius="4" Padding="16,10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                            Visibility="{Binding IsChecked, ElementName=swAutoExtract, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="ORGANIZE EXTRACTED ASSETS" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Black"/>
                                <TextBlock Text="Keep original directory structure during extraction" Foreground="{StaticResource TextMuted}" FontSize="9"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding Settings.OrganizeExtractedAssets, Mode=TwoWay}" Style="{StaticResource ModernToggleSwitch}"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- Report -->
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Generate asset report" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                            <TextBlock Text="Create a technical assets.log file with comparison details" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="swGenerateReport" Grid.Column="1" 
                                  IsChecked="{Binding Settings.ReportGeneration.Enabled, Mode=TwoWay}" 
                                  IsEnabled="{Binding IsChecked, ElementName=swAutoExtract, Converter={StaticResource InverseBooleanConverter}}"
                                  Style="{StaticResource ModernToggleSwitch}"/>
                    </Grid>

                    <Border Margin="0,12,0,0" Background="{StaticResource CardBackground}" CornerRadius="4" Padding="16,10" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                            Visibility="{Binding IsChecked, ElementName=swGenerateReport, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="REPORT FILTERS" Foreground="{StaticResource TextSecondary}" FontSize="10" FontWeight="Black" Margin="0,0,0,12"/>
                            <WrapPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding Settings.ReportGeneration.FilterNew, Mode=TwoWay}" Content="NEW" Style="{StaticResource ModernCheckBox}" Margin="0,0,16,0" FontSize="10"/>
                                <CheckBox IsChecked="{Binding Settings.ReportGeneration.FilterModified, Mode=TwoWay}" Content="MODIFIED" Style="{StaticResource ModernCheckBox}" Margin="0,0,16,0" FontSize="10"/>
                                <CheckBox IsChecked="{Binding Settings.ReportGeneration.FilterRenamed, Mode=TwoWay}" Content="RENAMED" Style="{StaticResource ModernCheckBox}" Margin="0,0,16,0" FontSize="10"/>
                                <CheckBox IsChecked="{Binding Settings.ReportGeneration.FilterRemoved, Mode=TwoWay}" Content="REMOVED" Style="{StaticResource ModernCheckBox}" FontSize="10"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- SECTION: EXPORT PROTOCOLS -->
        <StackPanel Margin="0,0,0,40">
            <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,12" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal">
                    <materialIcons:MaterialIcon Kind="FileExportOutline" Foreground="{StaticResource AccentBrush}" Width="18" Height="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="EXPORT PROTOCOLS" FontSize="12" FontWeight="Black" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="0,1,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Margin="28,0,0,0">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Audio encoding target" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                        <TextBlock Text="Target conversion format for Wwise .wem containers" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="120" Height="30" Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding AudioFormatOptions}" DisplayMemberPath="Name" SelectedValuePath="Value"
                              SelectedValue="{Binding Settings.AudioExportFormat, Mode=TwoWay}"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Image rendering target" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" FontSize="13"/>
                        <TextBlock Text="Preferred format for texture and asset extraction" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ComboBox Grid.Column="1" Width="120" Height="30" Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding ImageFormatOptions}" DisplayMemberPath="Name" SelectedValuePath="Value"
                              SelectedValue="{Binding Settings.ImageExportFormat, Mode=TwoWay}"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </StackPanel>
</UserControl>
